---
import "../styles/components/InfoModals.scss";
---

<section id="modals">
  <dialog id="info-notepad" class="settings-modal">
    <div class="settings-container">
      <!-- Sidebar izquierdo -->
      <div class="settings-sidebar">
        <div class="user-section">
          <h2 class="flex items-center justify-start">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 7.5V6.108c0-1.135.845-2.098 1.976-2.192.373-.03.748-.057 1.123-.08M15.75 18H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08M15.75 18.75v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5A3.375 3.375 0 0 0 6.375 7.5H5.25m11.9-3.664A2.251 2.251 0 0 0 15 2.25h-1.5a2.251 2.251 0 0 0-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9Z"
              ></path>
            </svg> TomaNote
          </h2>
          <span class="version">v 0.3.0</span>
        </div>

        <nav class="settings-nav">
          <button class="nav-item active" data-tab="about">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"></path>
              </svg>
            </span>
            Acerca de
          </button>
          <button class="nav-item" data-tab="license">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z"
                ></path>
              </svg>
            </span>
            Licencia
          </button>
          <button class="nav-item" data-tab="terms">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"></path>
              </svg>
            </span>
            Términos de uso
          </button>
          <button class="nav-item" data-tab="fonts">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"></path>
              </svg>
            </span>
            Fuentes
          </button>
        </nav>

        <form method="dialog" class="sidebar-footer">
          <button class="save-button flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
            </svg>
            Aceptar
          </button>
        </form>
      </div>

      <!-- Contenido principal -->
      <div class="settings-content">
        <!-- Pestaña Acerca de -->
        <div class="settings-tab active" id="about-tab">
          <div class="settings-header">
            <h3><u>Acerca de TomaNote</u></h3>
          </div>
          <div class="settings-body">
            <!-- Contenido de la licencia existente -->
            <h4>TomaNote es un bloc de notas simple, rápido y gratuito, diseñado para escribir sin distracciones.</h4><br />
            <h4>Funciona directamente en tu navegador y no requiere cuentas ni registro. Todas tus notas se guardan localmente en tu dispositivo, lo que significa que tú mantienes el control total de tu información.</h4><br />
            <h6>TomaNote prioriza:</h6><br />
            <ul class="list-disc list-inside">
              <li>Simplicidad</li>
              <li>Velocidad</li>
              <li>Privacidad</li>
              <li>Uso sin fricción</li>
            </ul>
            <br />
            <h4>No es una plataforma de productividad compleja ni un gestor de proyectos. Es un espacio limpio para pensar, escribir y organizar ideas.</h4><br />
            <div class="settings-header">
              <h3><u>Importante</u></h3>
            </div>
            <h4>Las notas se almacenan en el almacenamiento local del navegador. Si borras los datos del navegador o recargas sin caché, la información se perderá. Se recomienda exportar o respaldar tus notas periódicamente.</h4><br />
            <div class="settings-header">
              <h3><u>Funcionalidades principales</u></h3>
            </div>
            <ul class="list-disc list-inside">
              <li>Edición de texto libre y sin distracciones</li>
              <li>Pestañas persistentes</li>
              <li>Guardado automático local</li>
              <li>Modo oscuro y personalización visual</li>
              <li>Uso offline</li>
            </ul>
            <br />
            <div class="settings-header">
              <h3><u>Filosofía</u></h3>
            </div>
            <h4>TomaNote existe porque escribir debería ser simple, gratuito y accesible, sin depender de servicios externos ni suscripciones.</h4><br />
            <!-- ... resto del contenido de la licencia ... -->
          </div>
        </div>

        <!-- Pestaña Licencia -->
        <div class="settings-tab" id="license-tab">
          <div class="settings-header">
            <h3>Licencia</h3>
          </div>
          <div class="settings-body">
            <!-- Contenido de la licencia existente -->
            <h4>
              <u>Licencia GNU Affero General Public License (AGPL) v3.0</u>
            </h4><br />
            <p>Este software está licenciado bajo la GNU Affero General Public License (AGPL) v3.0. La licencia AGPL v3.0 garantiza a los usuarios la libertad de usar, estudiar, modificar y distribuir el software, bajo las siguientes condiciones:</p><br />
            <p>
              <strong>Libre Uso:</strong> El software puede ser utilizado para cualquier propósito, sin restricciones.
            </p><br />
            <p>
              <strong>Modificación:</strong> Los usuarios pueden modificar el software y distribuir las versiones modificadas.
            </p><br />
            <p>
              <strong>Distribución:</strong> Cualquier copia del software, ya sea en su forma original o modificada, debe incluir la misma licencia AGPL v3.0.
            </p><br />
            <strong>Cláusula Adicional: Restricción de Uso Comercial</strong><br />
            <p>Los usuarios no pueden utilizar el software para fines comerciales, excepto si han obtenido autorización previa por escrito del desarrollador.</p><br />
            <p>
              <strong>Uso Comercial Restringido:</strong> Se prohíbe la comercialización directa o indirecta de este software, incluyendo pero no limitado a la venta, arrendamiento, sublicenciamiento, o cualquier otro uso con fines comerciales, sin el consentimiento expreso y por escrito del titular original de los derechos de autor. Esta restricción no afecta los derechos de los usuarios a modificar, mejorar o redistribuir el software siempre que dichas actividades no impliquen un uso comercial.
            </p><br />
            <p>Para obtener permisos específicos relacionados con el uso comercial, por favor contacta al titular de los derechos de autor.</p><br />
            <!-- ... resto del contenido de la licencia ... -->
          </div>
        </div>

        <!-- Pestaña Términos -->
        <div class="settings-tab" id="terms-tab">
          <div class="settings-header">
            <h3>Términos de Uso</h3>
            <h6>Términos y Advertencias para el Uso del Bloc de Notas</h6>
          </div>
          <div class="settings-body">
            <!-- Contenido de los términos existente -->
            <h4><u>Límite de Almacenamiento</u></h4><br />
            <p>Este Bloc de Notas utiliza el LocalStorage de tu navegador para guardar la información. Aunque el límite de almacenamiento es de 5 MB, te recomiendo no almacenar grandes volúmenes de texto. Ten en cuenta que el almacenamiento en el navegador es limitado y puede verse afectado si guardas grandes cantidades de información. Si alcanzas el límite, podrías perder datos, por lo que sugerimos realizar copias de seguridad regularmente.</p><br />
            <h4><u>Seguridad de la Información</u></h4><br />
            <p>La información que guardas en este Bloc de Notas no está encriptada y se almacena en el LocalStorage de tu navegador, lo cual no garantiza su seguridad. Te recomiendo no guardar información sensible o privada en esta herramienta, ya que podría ser vulnerable a accesos no autorizados si otros usuarios tienen acceso a tu dispositivo o navegador.</p><br />
            <h4><u>Precaución con la URL</u></h4><br />
            <p>Asegúrate de que estás utilizando una URL confiable y segura al acceder al Bloc de Notas. Evita acceder desde enlaces sospechosos o en redes públicas no seguras, ya que podrías exponerte a ataques de suplantación de identidad (phishing) o robo de datos. Te recordamos que el equipo de desarrollo no se responsabiliza por la pérdida de datos debido a usos inapropiados de la herramienta o acceso no seguro.</p>
            <!-- ... resto del contenido de los términos ... -->
          </div>
        </div>

        <!-- Pestaña Fuentes -->
        <div class="settings-tab" id="fonts-tab">
          <div class="settings-header">
            <h3>Fuentes personalizadas</h3>
          </div>

          <div class="settings-body" style="max-height: 55vh; overflow-y: auto;">
            <div class="settings-section">
              <h4>URL de Google Fonts</h4>

              <div style="display: flex; gap: 8px; align-items: center;">
                <input id="font-url-input" type="text" placeholder="Introduce una URL válida de Google Fonts" style="flex:1; padding: 8px; border-radius: 6px; border: 1px solid #ccc;" />
                <button id="save-font-url" class="flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 mr-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z"></path>
                  </svg>
                  Guardar fuente
                </button>
              </div>

              <div id="font-url-error" style="color: #dc3545; margin-top: 8px; display: none;"></div>
            </div>

            <div class="settings-section">
              <h4>Configuración de fuentes</h4>

              <ol class="list-decimal pl-[2rem]!">
                <li>
                  Accede a <a href="https://fonts.google.com/" target="_blank">Google Fonts</a> y selecciona la fuente que deseas utilizar.
                </li>
                <li>
                  Obtén la URL de carga desde la opción <code>Get embed code</code> / <code>Obtener código de inserción</code>.
                </li>
                <li>
                  Copia la URL correspondiente al elemento <code>&lt;link&gt;</code> (debe comenzar con <code>https://fonts.googleapis.com/</code>).
                </li>
                <li>
                  Pega la URL en el campo superior y selecciona <strong>Guardar fuente</strong>.
                </li>
              </ol>

              <p style="margin-top: 0.75rem; opacity: 0.85;">La configuración de la fuente se guarda localmente en este navegador y se aplica automáticamente.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </dialog>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("info-notepad") as HTMLElement | null;
    if (!modal) return;
    const navItems = modal.querySelectorAll(".nav-item");
    const tabs = modal.querySelectorAll(".settings-tab");

    // Función para cambiar pestañas
    function switchTab(tabId: string) {
      if (!modal) return;
      navItems.forEach((item) => item.classList.remove("active"));
      tabs.forEach((tab) => tab.classList.remove("active"));

      const selectedTab = modal.querySelector(`#${tabId}-tab`) as HTMLElement | null;
      const selectedNav = modal.querySelector(`[data-tab="${tabId}"]`) as HTMLElement | null;
      if (selectedTab && selectedNav) {
        selectedTab.classList.add("active");
        selectedNav.classList.add("active");
      }
    }

    // Manejador de clics en la navegación
    navItems.forEach((item) => {
      item.addEventListener("click", () => {
        const tabId = (item as HTMLElement).dataset.tab;
        if (tabId) switchTab(tabId);
      });
    });

    // --- FUENTES PERSONALIZADAS ---
    const fontInput = document.getElementById("font-url-input") as HTMLInputElement | null;
    const saveFontBtn = document.getElementById("save-font-url") as HTMLButtonElement | null;
    const fontError = document.getElementById("font-url-error") as HTMLDivElement | null;

    // Cargar valor guardado si existe
    if (fontInput && localStorage.getItem("customFontUrl")) {
      fontInput.value = localStorage.getItem("customFontUrl") || "";
    }

    function isValidGoogleFontsUrl(url: string): boolean {
      try {
        const parsed = new URL(url);
        return parsed.hostname === "fonts.googleapis.com" && parsed.protocol === "https:";
      } catch {
        return false;
      }
    }

    if (saveFontBtn && fontInput && fontError) {
      saveFontBtn.addEventListener("click", () => {
        const url = fontInput.value.trim();
        if (!isValidGoogleFontsUrl(url)) {
          fontError.textContent = "Por favor ingresa una URL válida de Google Fonts (https://fonts.googleapis.com/...)";
          fontError.style.display = "block";
          return;
        }
        fontError.style.display = "none";
        localStorage.setItem("customFontUrl", url);
        // Recargar para aplicar la fuente
        location.reload();
      });
    }
  });
</script>
