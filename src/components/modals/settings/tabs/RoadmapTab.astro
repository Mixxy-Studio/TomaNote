---
// RoadmapTab.astro - Settings Modal - Roadmap Tab

// Languages
import { getLang, useTranslations } from "../../../../i18n/utils";
const lang = getLang();
const t = useTranslations(lang);

// Icons
import Icon from "../../../icons/Icon.astro";
---

<div class="settings-tab hidden [&.active]:block" id="roadmap-tab">
  <div class="settings-header mb-[24px]! text-center">
    <h3><u data-i18n="roadmap.title"></u></h3>
  </div>
  <hr />
  <div class="settings-body">
    <div class="p-4!">
      <div class="grid 2xl:grid-cols-3 gap-4! items-start">
        <!-- Columna 1: Anterior -->
        <div class="bg-(--tn-theme-secondary) rounded-xl border border-(--tn-theme-accent)/30 overflow-hidden hover:shadow transition-all! duration-300! ease-in-out! cursor-default hover:scale-101">
          <div class="px-4! py-3! border-b border-(--tn-theme-accent)/30">
            <span class="text-[11px] font-medium text-(--tn-color-text)/50 uppercase tracking-widest" data-i18n="roadmap.prev"></span>
            <p class="mt-1! text-[15px] font-medium text-(--tn-color-text)" data-i18n="roadmap.prev-version"></p>
            <p class="mt-0.5! text-xs text-(--tn-color-text)/50" data-i18n="roadmap.prev-date"></p>
          </div>
          <div class="px-4! py-3!">
            <ul class="flex flex-col gap-1! list-none! p-0! m-0!">
              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/40">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.prev-summary-1"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/50 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.prev-desc-1"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/40">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.prev-summary-2"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/50 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.prev-desc-2"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/40">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.prev-summary-3"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/50 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.prev-desc-3"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/40">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.prev-summary-4"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/50 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.prev-desc-4"></p>
                </details>
              </li>
            </ul>
            <a target="_blank" href={t("roadmap.changelog-link")} class="inline-block mt-3! text-xs text-(--tn-theme-contrast) no-underline" data-i18n="roadmap.viewChangelog"></a>
          </div>
        </div>

        <!-- Columna 2: Actual (destacada) -->
        <div class="bg-(--tn-theme-contrast)/20 rounded-xl border-2 border-(--tn-theme-contrast) overflow-hidden hover:shadow transition-all! duration-300! ease-in-out! cursor-default hover:scale-101">
          <div class="px-4! py-3! border-b border-(--tn-theme-contrast)/30">
            <span class="inline-block text-[11px] font-medium bg-(--tn-theme-contrast) text-(--tn-neutral-tertiary-color) px-2! py-0.5! rounded-md mb-1.5!" data-i18n="roadmap.current"></span>
            <p class="mt-1! text-[15px] font-medium text-(--tn-color-text)" data-i18n="roadmap.current-version"></p>
            <p class="mt-0.5! text-xs text-(--tn-color-text)/50" data-i18n="roadmap.current-date"></p>
          </div>
          <div class="px-4! py-3!">
            <ul class="flex flex-col gap-1! list-none! p-0! m-0!">
              <li class="border-b border-(--tn-theme-contrast)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text) pl-3! border-l-2 border-(--tn-theme-contrast)">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.current-summary-1"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/60 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.current-desc-1"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-contrast)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text) pl-3! border-l-2 border-(--tn-theme-contrast)">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.current-summary-2"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/60 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.current-desc-2"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-contrast)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text) pl-3! border-l-2 border-(--tn-theme-contrast)">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.current-summary-3"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/60 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.current-desc-3"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-contrast)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text) pl-3! border-l-2 border-(--tn-theme-contrast)">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.current-summary-4"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/60 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.current-desc-4"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-contrast)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text) pl-3! border-l-2 border-(--tn-theme-contrast)">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.current-summary-5"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/60 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.current-desc-5"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-contrast)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text) pl-3! border-l-2 border-(--tn-theme-contrast)">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.current-summary-6"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/60 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed" data-i18n="roadmap.current-desc-6"></p>
                </details>
              </li>
            </ul>
          </div>
        </div>

        <!-- Columna 3: Proxima -->
        <div class="bg-(--tn-theme-secondary) rounded-xl border border-(--tn-theme-accent)/30 overflow-hidden opacity-75 hover:shadow transition-all! duration-300! ease-in-out! cursor-default hover:scale-101">
          <div class="px-4! py-3! border-b border-(--tn-theme-accent)/30">
            <span class="text-[11px] font-medium text-(--tn-color-text)/50 uppercase tracking-widest" data-i18n="roadmap.next"></span>
            <p class="mt-1! text-[15px] font-medium text-(--tn-color-text)" data-i18n="roadmap.next-version"></p>
            <p class="mt-0.5! text-xs text-(--tn-color-text)/50" data-i18n="roadmap.next-date"></p>
          </div>
          <div class="px-4! py-3!">
            <ul class="flex flex-col gap-1! list-none! p-0! m-0!">
              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/30 italic">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.next-summary-1"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/40 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed italic" data-i18n="roadmap.next-desc-1"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/30 italic">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.next-summary-2"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/40 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed italic" data-i18n="roadmap.next-desc-2"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/30 italic">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.next-summary-3"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/40 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed italic" data-i18n="roadmap.next-desc-3"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/30 italic">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.next-summary-4"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/40 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed italic" data-i18n="roadmap.next-desc-4"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/30 italic">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.next-summary-5"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/40 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed italic" data-i18n="roadmap.next-desc-5"></p>
                </details>
              </li>

              <li class="border-b border-(--tn-theme-accent)/20 last:border-0">
                <details class="group">
                  <summary class="flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] text-(--tn-color-text)/70 pl-3! border-l-2 border-(--tn-theme-accent)/30 italic">
                    <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                    <span data-i18n="roadmap.next-summary-6"></span>
                  </summary>
                  <p class="text-[12px] text-(--tn-color-text)/40 pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed italic" data-i18n="roadmap.next-desc-6"></p>
                </details>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
