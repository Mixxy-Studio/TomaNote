---
// Styles
import "../styles/components/InfoModals.scss";

// Icons
import Icon from "../components/icons/Icon.astro";
---

<section id="modals">
  <dialog id="info-notepad" class="settings-modal">
    <div class="settings-container">
      <!-- Sidebar izquierdo -->
      <div class="settings-sidebar">
        <div class="user-section">
          <h2 class="flex items-center justify-start">
            <Icon name="tomanote" className="size-1 md:size-6" />
            TomaNote
          </h2>
          <span class="version">v 0.4.0</span>
        </div>

        <nav class="settings-nav">
          <button class="nav-item active" data-tab="about">
            <span class="icon">
              <Icon name="about" className="size-1 md:size-6" />
            </span>
            About
          </button>
          <button class="nav-item" data-tab="license">
            <span class="icon">
              <Icon name="license" className="size-1 md:size-6" />
            </span>
            Licence
          </button>
          <button class="nav-item" data-tab="terms">
            <span class="icon">
              <Icon name="terms" className="size-1 md:size-6" />
            </span>
            Terms
          </button>
          <button class="nav-item" data-tab="roadmap">
            <span class="icon">
              <Icon name="roadmap" className="size-1 md:size-6" />
            </span>
            Roadmap
          </button>
          <button class="nav-item" data-tab="fonts">
            <span class="icon">
              <Icon name="tipo" className="size-1 md:size-6" />
            </span>
            Typography
          </button>
          <button class="nav-item" data-tab="theme">
            <span class="icon">
              <Icon name="theme" className="size-1 md:size-6" />
            </span>
            Theme
          </button>
          <button class="nav-item" data-tab="lang">
            <span class="icon">
              <Icon name="lang" className="size-1 md:size-6" />
            </span>
            Language
          </button>
        </nav>

        <form enctype="application/x-www-form-urlencoded" method="dialog" class="sidebar-footer">
          <button class="save-button flex items-center justify-center gap-2">
            <Icon name="check" className="size-1 md:size-6" />
            Aceptar
          </button>
        </form>
      </div>

      <!-- Contenido principal -->
      <div class="settings-content">
        
        <!-- Pestaña Acerca de -->
        <div class="settings-tab active" id="about-tab">
          <div class="settings-header">
            <h3><u>Acerca de TomaNote</u></h3>
          </div>
          <div class="settings-body">
            <!-- Contenido de la licencia existente -->
            <h4>TomaNote es un bloc de notas simple, rápido y gratuito, diseñado para escribir sin distracciones.</h4><br />
            <h4>Funciona directamente en tu navegador y no requiere cuentas ni registro. Todas tus notas se guardan localmente en tu dispositivo, lo que significa que tú mantienes el control total de tu información.</h4><br />
            <h6>TomaNote prioriza:</h6><br />
            <ul class="list-disc list-inside pl-5!">
              <li>Simplicidad</li>
              <li>Velocidad</li>
              <li>Privacidad</li>
              <li>Uso sin fricción</li>
            </ul>
            <br />
            <h4>No es una plataforma de productividad compleja ni un gestor de proyectos. Es un espacio limpio para pensar, escribir y organizar ideas.</h4><br />
            <div class="settings-header">
              <h3><u>Importante</u></h3>
            </div>
            <h4>Las notas se almacenan en el almacenamiento local del navegador. Si borras los datos del navegador o recargas sin caché, la información se perderá. Se recomienda exportar o respaldar tus notas periódicamente.</h4><br />
            <div class="settings-header">
              <h3><u>Funcionalidades principales</u></h3>
            </div>
            <ul class="list-disc list-inside pl-5!">
              <li>Edición de texto libre y sin distracciones</li>
              <li>Pestañas persistentes</li>
              <li>Guardado automático local</li>
              <li>Modo oscuro y personalización visual</li>
              <li>Uso offline</li>
            </ul>
            <br />
            <div class="settings-header">
              <h3><u>Filosofía</u></h3>
            </div>
            <h4>TomaNote existe porque escribir debería ser simple, gratuito y accesible, sin depender de servicios externos ni suscripciones.</h4><br />
            <!-- ... resto del contenido de la licencia ... -->
          </div>
        </div>

        <!-- Pestaña Licencia -->
        <div class="settings-tab" id="license-tab">
          <div class="settings-header">
            <h3>Licencia</h3>
          </div>
          <div class="settings-body">
            <!-- Contenido de la licencia existente -->
            <h4>
              <u>Licencia GNU Affero General Public License (AGPL) v3.0</u>
            </h4><br />
            <p>Este software está licenciado bajo la GNU Affero General Public License (AGPL) v3.0. La licencia AGPL v3.0 garantiza a los usuarios la libertad de usar, estudiar, modificar y distribuir el software, bajo las siguientes condiciones:</p><br />
            <p>
              <strong>Libre Uso:</strong> El software puede ser utilizado para cualquier propósito, sin restricciones.
            </p><br />
            <p>
              <strong>Modificación:</strong> Los usuarios pueden modificar el software y distribuir las versiones modificadas.
            </p><br />
            <p>
              <strong>Distribución:</strong> Cualquier copia del software, ya sea en su forma original o modificada, debe incluir la misma licencia AGPL v3.0.
            </p><br />
            <strong>Cláusula Adicional: Restricción de Uso Comercial</strong><br />
            <p>Los usuarios no pueden utilizar el software para fines comerciales, excepto si han obtenido autorización previa por escrito del desarrollador.</p><br />
            <p>
              <strong>Uso Comercial Restringido:</strong> Se prohíbe la comercialización directa o indirecta de este software, incluyendo pero no limitado a la venta, arrendamiento, sublicenciamiento, o cualquier otro uso con fines comerciales, sin el consentimiento expreso y por escrito del titular original de los derechos de autor. Esta restricción no afecta los derechos de los usuarios a modificar, mejorar o redistribuir el software siempre que dichas actividades no impliquen un uso comercial.
            </p><br />
            <p>Para obtener permisos específicos relacionados con el uso comercial, por favor contacta al titular de los derechos de autor.</p><br />
            <!-- ... resto del contenido de la licencia ... -->
          </div>
        </div>

        <!-- Pestaña Términos -->
        <div class="settings-tab" id="terms-tab">
          <div class="settings-header">
            <h3>Términos de Uso</h3>
            <h6>Términos y Advertencias para el Uso del Bloc de Notas</h6>
          </div>
          <div class="settings-body">
            <!-- Contenido de los términos existente -->
            <h4><u>Límite de Almacenamiento</u></h4><br />
            <p>Este Bloc de Notas utiliza el LocalStorage de tu navegador para guardar la información. Aunque el límite de almacenamiento es de 5 MB, te recomiendo no almacenar grandes volúmenes de texto. Ten en cuenta que el almacenamiento en el navegador es limitado y puede verse afectado si guardas grandes cantidades de información. Si alcanzas el límite, podrías perder datos, por lo que sugerimos realizar copias de seguridad regularmente.</p><br />
            <h4><u>Seguridad de la Información</u></h4><br />
            <p>La información que guardas en este Bloc de Notas no está encriptada y se almacena en el LocalStorage de tu navegador, lo cual no garantiza su seguridad. Te recomiendo no guardar información sensible o privada en esta herramienta, ya que podría ser vulnerable a accesos no autorizados si otros usuarios tienen acceso a tu dispositivo o navegador.</p><br />
            <h4><u>Precaución con la URL</u></h4><br />
            <p>Asegúrate de que estás utilizando una URL confiable y segura al acceder al Bloc de Notas. Evita acceder desde enlaces sospechosos o en redes públicas no seguras, ya que podrías exponerte a ataques de suplantación de identidad (phishing) o robo de datos. Te recordamos que el equipo de desarrollo no se responsabiliza por la pérdida de datos debido a usos inapropiados de la herramienta o acceso no seguro.</p>
            <!-- ... resto del contenido de los términos ... -->
          </div>
        </div>

        <!-- Pestaña Roadmap -->
        <div class="settings-tab" id="roadmap-tab">
          
          <div class="settings-header">
            <h3>Roadmap de Desarrollo Tomanote</h3>
          </div>

          <div class="settings-body">
            <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Enim, consequatur.</p>
          </div>

        </div>

        <!-- Pestaña Tipografia -->
        <div class="settings-tab" id="fonts-tab">
          
          <div class="settings-header">
            <h3 class="font-black underline">Configuracion Tipografica</h3>
          </div>

          <div class="settings-body">
            <div class="settings-section">
              <h4 class="font-medium! text-xl!">Fuente personalizada (Google Fonts)</h4>

              <div class="settings-section__group">
                <input id="font-url-input" class="placeholder:text-(--tn-neutral-tertiary-color)! placeholder:opacity-40" type="text" placeholder="Introduce una URL válida de Google Fonts o deja vacío para fuente por defecto" />
                <button id="save-font-url" class="flex items-center justify-center">
                  <Icon name="save" className="size-1 md:size-6 mr-2!" />
                  Guardar Fuente
                </button>
              </div>

              <div id="font-url-error" class="bg-red-600 mt-4! hidden text-white rounded-md px-3!"></div>
            </div>

            <div class="settings-section">
              <h4>Configuración de fuentes</h4>

              <ul role="list" class="list-disc pl-3!">
                <li class="block md:inline-flex items-center my-2! before:content-['·'] before:text-inherit! md:before:text-6xl! before:leading-0! before:mr-3!">
                  Accede a <a href="https://fonts.google.com/" target="_blank" class="mx-1!">Google Fonts</a> y seleccionas la fuente que deseas utilizar.
                </li>
                <li class="block md:inline-flex items-center my-2! before:content-['·'] before:text-inherit! md:before:text-6xl! before:leading-0! before:mr-3!">
                  Obtén la URL de carga desde la opción <code class="mx-1!">Get embed code</code> / <code class="mx-1!">Obtener código de inserción</code>.
                </li>
                <li class="block md:inline-flex items-center my-2! before:content-['·'] before:text-inherit! md:before:text-6xl! before:leading-0! before:mr-3!">
                  Copia la URL correspondiente al elemento <code class="mx-1!">&lt;link&gt;</code>. (Debe comenzar con <code class="mx-1!">https://fonts.googleapis.com/</code>).
                </li>
                <li class="block md:inline-flex items-center my-2! before:content-['·'] before:text-inherit! md:before:text-6xl! before:leading-0! before:mr-3!">
                  Pega la URL en el campo superior y selecciona <strong>Guardar fuente</strong>.
                </li>
              </ul>

              <p class="mt-3!">La configuración de la fuente se guarda localmente en este navegador y se aplica automáticamente.</p>
            </div>

            <hr />

            <div class="settings-section mt-5!">
              <h4 class="font-medium! text-xl!">Tamaño de fuente</h4>
              <p>Controla el tamaño del texto en el editor</p>

              <div class="settings-form grid grid-rows-3 md:grid-rows-1 md:grid-cols-3 gap-5">

                <div class="group flex flex-col gap-2 mb-5!">
                  <h4 class="mb-0! mt-3!">Base</h4>
                  <input type="radio" name="options-font-size" class="hidden peer" id="option-compact-text" checked>
                  <label for="option-compact-text" class="w-full max-w-[300px] h-[100px] md:h-[300px] overflow-hidden text-ellipsis! flex items-start justify-center p-5! border-2 border-(--tn-theme-accent) rounded-lg cursor-pointer peer-checked:border-(--tn-theme-contrast)">
                    <p class="base-text text-(--color-text)">Lorem ipsum, dolor sit amet consectetur adipisicing elit. Ea at quos quaerat est aliquid fugit, iusto blanditiis, sunt omnis culpa pariatur optio magnam minima cumque! Ipsa nisi, iste aperiam a officiis voluptatem quis repellendus distinctio minus! Voluptas omnis perspiciatis porro animi fugit ullam commodi, voluptates officia obcaecati harum maiores quisquam.</p>
                  </label>
                </div>

                <div class="group flex flex-col gap-2 mb-5!">
                  <h4 class="mb-0! mt-3!">Medium</h4>
                  <input type="radio" name="options-font-size" class="hidden peer" id="option-normal-text">
                  <label for="option-normal-text" class="w-full max-w-[300px] h-[100px] md:h-[300px] overflow-hidden text-ellipsis! flex items-start justify-center p-5! border-2 border-(--tn-theme-accent) rounded-lg cursor-pointer peer-checked:border-(--tn-theme-contrast)">
                    <p class="medium-text text-(--color-text)">Lorem ipsum dolor sit amet consectetur adipisicing elit. Quas delectus ratione accusantium est vel quis, ut autem eos minima nam enim assumenda ea nesciunt blanditiis, dolor voluptas voluptate dolores officiis. Est ex ipsam odio temporibus. Distinctio, earum est cum at in quia, praesentium quod commodi exercitationem mollitia, ex cupiditate omnis?</p>
                  </label>
                </div>

                <div class="group flex flex-col gap-2 mb-5!">
                  <h4 class="mb-0! mt-3!">Large</h4>
                  <input type="radio" name="options-font-size" class="hidden peer" id="option-large-text">
                  <label for="option-large-text" class="w-full max-w-[300px] h-[100px] md:h-[300px] overflow-hidden text-ellipsis! flex items-start justify-center p-5! border-2 border-(--tn-theme-accent) rounded-lg cursor-pointer peer-checked:border-(--tn-theme-contrast)">
                    <p class="large-text text-(--color-text)">Lorem ipsum dolor sit amet consectetur adipisicing elit. Quas delectus ratione accusantium est vel quis, ut autem eos minima nam enim assumenda ea nesciunt blanditiis, dolor voluptas voluptate dolores officiis. Est ex ipsam odio temporibus. Distinctio, earum est cum at in quia, praesentium quod commodi exercitationem mollitia, ex cupiditate omnis?</p>
                  </label>
                </div>

              </div>
            </div>
          </div>
        </div>

        <!-- Pestaña Theme -->
        <div class="settings-tab" id="theme-tab">
          
          <div class="settings-header">
            <h3>Selecciona tu tema favorito</h3>
          </div>

          <div class="settings-body">
            <p>Lorem, ipsum dolor sit amet consectetur adipisicing elit. Sed, dolorem.</p>
          </div>
        </div>

        <!-- Pestaña Language -->
        <div class="settings-tab" id="lang-tab">
          
          <div class="settings-header">
            <h3>Idioma</h3>
          </div>

          <div class="settings-body">
            <p>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Ipsa, atque.</p>
          </div>
        </div>

      </div>
    </div>
  </dialog>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("info-notepad") as HTMLElement | null;
    if (!modal) return;
    const navItems = modal.querySelectorAll(".nav-item");
    const tabs = modal.querySelectorAll(".settings-tab");

    // Función para cambiar pestañas
    function switchTab(tabId: string) {
      if (!modal) return;
      navItems.forEach((item) => item.classList.remove("active"));
      tabs.forEach((tab) => tab.classList.remove("active"));

      const selectedTab = modal.querySelector(`#${tabId}-tab`) as HTMLElement | null;
      const selectedNav = modal.querySelector(`[data-tab="${tabId}"]`) as HTMLElement | null;
      if (selectedTab && selectedNav) {
        selectedTab.classList.add("active");
        selectedNav.classList.add("active");
      }
    }

    // Manejador de clics en la navegación
    navItems.forEach((item) => {
      item.addEventListener("click", () => {
        const tabId = (item as HTMLElement).dataset.tab;
        if (tabId) switchTab(tabId);
      });
    });

    // --- FUENTES PERSONALIZADAS ---
    const fontInput = document.getElementById("font-url-input") as HTMLInputElement | null;
    const saveFontBtn = document.getElementById("save-font-url") as HTMLButtonElement | null;
    const fontError = document.getElementById("font-url-error") as HTMLDivElement | null;

    // Cargar valor guardado si existe
    if (fontInput && localStorage.getItem("customFontUrl")) {
      fontInput.value = localStorage.getItem("customFontUrl") || "";
    }

    function isValidGoogleFontsUrl(url: string): boolean {
      try {
        const parsed = new URL(url);
        return parsed.hostname === "fonts.googleapis.com" && parsed.protocol === "https:";
      } catch {
        return false;
      }
    }

    if (saveFontBtn && fontInput && fontError) {
      saveFontBtn.addEventListener("click", () => {
        const url = fontInput.value.trim();
        
        // Caso 1: Input vacío = restaurar fuente por defecto
        if (url === "") {
          fontError.style.display = "none";
          localStorage.removeItem("customFontUrl");
          localStorage.removeItem("customFontName");
          location.reload();
          return;
        }
        
        // Caso 2: URL válida de Google Fonts
        if (isValidGoogleFontsUrl(url)) {
          fontError.style.display = "none";
          localStorage.setItem("customFontUrl", url);
          location.reload();
          return;
        }
        
        // Caso 3: Input inválido
        fontError.textContent = "Por favor ingresa una URL válida de Google Fonts o deja el campo vacío para usar la fuente por defecto.";
        fontError.style.display = "inline-block";
      });
    }
  });
</script>
