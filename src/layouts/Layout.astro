---
// Styles
import "../styles/base/Reset.scss";
import "../styles/vendors/global.css";
import "../styles/components/ThemeSelector.scss";
import "../styles/components/Animations.scss";
import "../styles/components/Icons.scss";

// Components
import EmptyState from "../components/EmptyState.astro";

// ─── Dynamic locale logic ───────────────────────────────────────────────────
// Astro runs this at build time (SSG) or request time (SSR).
// For a purely client-side SPA the values below are the safe static defaults;
// swap for Astro i18n helpers once you add real routes.
const locale = "en"; // TODO: replace with Astro.currentLocale
const ogLocale = "en_US";
const siteUrl = "https://tomanote.app";
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
{
  /*
  FIX (a11y – HIGH): lang attribute added so screen readers use the correct
  language/voice. Previously missing entirely from <html>.
  TODO: replace hardcoded "en" with your i18n locale variable when routes exist.
  */
}
<html lang={locale}>
  <head>
    {
      /*
      FIX (a11y – HIGH): moved lang detection BEFORE any render so the
      document language is declared at parse time, not after JS runs.
      data-lang is still set for JS components that need it.
    */
    }
    <script is:inline>
      (function () {
        const lang = navigator.language?.toLowerCase().startsWith("es") ? "es" : "en";
        document.documentElement.setAttribute("data-lang", lang);
      })();
    </script>

    {/* === BASIC META TAGS === */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* === SEO META TAGS === */}
    <title>TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done</title>
    <meta name="description" content="A minimal notepad for people who just want to write. Fast, offline-first, and completely free." />
    <meta name="author" content="Camiicode" />
    <meta name="keywords" content="notes, notepad, tabs, editor, offline, pwa, productivity, web-app, fast notes" />

    {/* === CANONICAL & ROBOTS === */}
    {
      /*
      FIX (SEO – MEDIUM): canonical is now dynamic so future pages (e.g. /es/)
      don't all point to the root, causing duplicate-content issues.
    */
    }
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    {
      /*
      FIX (SEO – MEDIUM): hreflang signals to Google which language version to
      serve. x-default is the fallback when no language matches.
      Currently both point to root; update hrefs once /es/ route exists.
    */
    }
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="es" href={siteUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    {/* === OPEN GRAPH / FACEBOOK === */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done" />
    <meta property="og:description" content="A minimal notepad for people who just want to write. Fast, offline-first, and completely free." />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Screenshot of TomaNote.app showing the editor with tabs" />
    {
      /*
      FIX (SEO – MEDIUM): og:locale is now dynamic instead of hardcoded es_ES.
      An English visitor sharing the page will now get en_US in the preview.
    */
    }
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocale === "en_US" ? "es_ES" : "en_US"} />
    <meta property="og:site_name" content="TomaNote App" />

    {/* === TWITTER CARDS === */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content="TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done" />
    <meta name="twitter:description" content="A minimal notepad for people who just want to write. Fast, offline-first, and completely free." />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:image:width" content="1200" />
    <meta name="twitter:image:height" content="630" />
    <meta name="twitter:image:alt" content="TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done" />
    <meta name="twitter:creator" content="@camiicode_x" />
    <meta name="twitter:site" content="@camiicode_x" />

    {/* === APP / PWA TAGS === */}
    <meta name="apple-mobile-web-app-title" content="TomaNote" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="msapplication-TileColor" content="#1a1a1a" />
    <meta name="msapplication-TileImage" content="/icon-144.png" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="color-scheme" content="dark light" />

    {/* === FONTS === */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,100..900;1,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />

    {
      /*
      FIX (SEO – HIGH): favicon was an inline data URI — Google and most browsers
      require a real file URL to display the favicon in search results and tabs.
      Place favicon.svg and icon-192.png in /public/.

      • favicon.svg        → shown in browser tabs (modern browsers)
      • favicon.ico        → fallback for older browsers / Google Search Console
      • icon-192.png       → Apple touch icon (home screen shortcut)
    */
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="192x192" href="/icon-192.png" />

    {/* === PWA Manifest === */}
    <link rel="manifest" href="/manifest.webmanifest" />

    {/* === SCHEMA.ORG === */}
    {
      /*
      FIX (SEO – LOW): aggregateRating with ratingCount: 1 is risky — Google
      may ignore or penalize thin review data. Remove it until you have real
      user ratings. Everything else in WebApplication schema is solid.
    */
    }
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "TomaNote App",
        "description": "A minimal notepad for people who just want to write. Fast, offline-first, and completely free.",
        "url": "https://tomanote.app",
        "applicationCategory": "ProductivityApplication",
        "operatingSystem": "Any",
        "browserRequirements": "Requires JavaScript. Requires HTML5.",
        "featureList": ["Multiple tabs", "Dark/light mode", "Context menu", "Auto-save", "Local storage", "PWA support"],
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Person",
          "name": "Camiicode",
          "url": "https://github.com/camiicode"
        },
        "publisher": {
          "@type": "Organization",
          "name": "TomaNote App",
          "logo": {
            "@type": "ImageObject",
            "url": "https://tomanote.app/icon-512.png",
            "width": "512",
            "height": "512"
          }
        },
        "screenshot": {
          "@type": "ImageObject",
          "url": "https://tomanote.app/screenshot-desktop.png",
          "width": "1280",
          "height": "720",
          "caption": "TomaNote App interface"
        }
      }
    </script>

    {
      /*
      FIX (SEO – MEDIUM): FAQ questions had Spanish punctuation (¿) but English
      text — inconsistent and confusing for both users and crawlers.
      Standardized to English since og:locale defaults to en_US.
      TODO: add a second FAQPage block in Spanish once /es/ route exists.
    */
    }
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is TomaNote App free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, TomaNote App is completely free and open source. It has no paid plans or premium versions."
            }
          },
          {
            "@type": "Question",
            "name": "Are my notes private?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. All notes are saved locally in your browser using localStorage. We don't collect, store, or transmit any data."
            }
          },
          {
            "@type": "Question",
            "name": "Do I need to create an account?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No, TomaNote App works completely without registration. It is 100% anonymous — no email or password required."
            }
          },
          {
            "@type": "Question",
            "name": "Does it work offline?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, after loading the app for the first time you can use it completely offline. All features are available without a connection."
            }
          },
          {
            "@type": "Question",
            "name": "Can I use TomaNote on my phone?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, TomaNote is a PWA (Progressive Web App). You can install it on your phone as a native app directly from the browser."
            }
          }
        ]
      }
    </script>
  </head>

  <body id="body" class="h-lvh relative">
    {
      /*
      FIX (a11y – MEDIUM): skip link lets keyboard and screen reader users jump
      directly to the editor, bypassing repeated navigation on every page load.
      Visually hidden until focused — no layout impact.
    */
    }
    <a href="#main-content" class="skip-link">Skip to content</a>

    <EmptyState />

    {
      /*
      FIX (a11y – LOW): <main> now has id="main-content" so the skip link above
      lands in the right place. role="main" is redundant on <main> but kept for
      older assistive tech that doesn't map the element automatically.
    */
    }
    <main id="main-content" role="main">
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  /*
    FIX (a11y – MEDIUM): skip link styles.
    Off-screen by default, moves into view on focus.
    Uses a high z-index so it's never obscured by the app UI.
  */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: #1a1a1a;
    color: #ffffff;
    font-size: 0.875rem;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    transition: top 0.15s ease;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
