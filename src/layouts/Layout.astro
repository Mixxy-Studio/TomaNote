---
// Styles
import "../styles/base/Reset.scss";
import "../styles/vendors/global.css";
import "../styles/components/ThemeSelector.scss";
import "../styles/components/Animations.scss";
import "../styles/components/Icons.scss";

// Components
import EmptyState from "../components/EmptyState.astro";

// ─── Dynamic locale logic ───────────────────────────────────────────────────

const locale = "en";
const ogLocale = "en_US";
const siteUrl = "https://tomanote.app";
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>
      (function () {
        const lang = navigator.language?.toLowerCase().startsWith("es") ? "es" : "en";
        document.documentElement.setAttribute("data-lang", lang);
      })();
    </script>

    {/* === BASIC META TAGS === */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="SGJ5zF51zD-nbfcfZ7nSzBg8ot489iV54FhGmlvVXX4" />

    {/* === SEO META TAGS === */}
    <title>TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done</title>
    <meta name="description" content="A minimal notepad for people who just want to write. Fast, offline-first, and completely free." />
    <meta name="author" content="Camiicode" />
    <meta name="keywords" content="notes, notepad, tabs, editor, offline, pwa, productivity, web-app, fast notes" />

    {/* === CANONICAL & ROBOTS === */}
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="es" href={siteUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    {/* === OPEN GRAPH / FACEBOOK === */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content="TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done" />
    <meta property="og:description" content="A minimal notepad for people who just want to write. Fast, offline-first, and completely free." />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Screenshot of TomaNote.app showing the editor with tabs" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocale === "en_US" ? "es_ES" : "en_US"} />
    <meta property="og:site_name" content="TomaNote App" />

    {/* === TWITTER CARDS === */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content="TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done" />
    <meta name="twitter:description" content="A minimal notepad for people who just want to write. Fast, offline-first, and completely free." />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:image:width" content="1200" />
    <meta name="twitter:image:height" content="630" />
    <meta name="twitter:image:alt" content="TomaNote.app - Just Notes. Nothing Else. Write, Autosave, Done" />
    <meta name="twitter:creator" content="@camiicode_x" />
    <meta name="twitter:site" content="@camiicode_x" />

    {/* === APP / PWA TAGS === */}
    <meta name="apple-mobile-web-app-title" content="TomaNote" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="msapplication-TileColor" content="#1a1a1a" />
    <meta name="msapplication-TileImage" content="/icon-144.png" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="color-scheme" content="dark light" />

    {/* === FONTS === */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400&family=Montserrat:wght@400&family=Open+Sans:wght@400&family=Poppins:wght@400&family=Raleway:wght@400&family=Roboto:wght@400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="192x192" href="/icon-192.png" />

    {/* === PWA Manifest === */}
    <link rel="manifest" href="/manifest.webmanifest" />

    {/* === SCHEMA.ORG === */}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "TomaNote App",
        "description": "A minimal notepad for people who just want to write. Fast, offline-first, and completely free.",
        "url": "https://tomanote.app",
        "applicationCategory": "ProductivityApplication",
        "operatingSystem": "Any",
        "browserRequirements": "Requires JavaScript. Requires HTML5.",
        "featureList": ["Multiple tabs", "Dark/light mode", "Context menu", "Auto-save", "Local storage", "PWA support"],
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Person",
          "name": "Camiicode",
          "url": "https://github.com/camiicode"
        },
        "publisher": {
          "@type": "Organization",
          "name": "TomaNote App",
          "logo": {
            "@type": "ImageObject",
            "url": "https://tomanote.app/icon-512.png",
            "width": "512",
            "height": "512"
          }
        },
        "screenshot": {
          "@type": "ImageObject",
          "url": "https://tomanote.app/screenshot-desktop.png",
          "width": "1280",
          "height": "720",
          "caption": "TomaNote App interface"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is TomaNote App free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, TomaNote App is completely free and open source. It has no paid plans or premium versions."
            }
          },
          {
            "@type": "Question",
            "name": "Are my notes private?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. All notes are saved locally in your browser using localStorage. We don't collect, store, or transmit any data."
            }
          },
          {
            "@type": "Question",
            "name": "Do I need to create an account?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No, TomaNote App works completely without registration. It is 100% anonymous — no email or password required."
            }
          },
          {
            "@type": "Question",
            "name": "Does it work offline?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, after loading the app for the first time you can use it completely offline. All features are available without a connection."
            }
          },
          {
            "@type": "Question",
            "name": "Can I use TomaNote on my phone?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, TomaNote is a PWA (Progressive Web App). You can install it on your phone as a native app directly from the browser."
            }
          }
        ]
      }
    </script>

    {/* === ORGANIZATION SCHEMA === */}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "TomaNote",
        "url": "https://tomanote.app",
        "description": "A minimal notepad for people who just want to write. Fast, offline-first, and completely free.",
        "sameAs": ["https://twitter.com/camiicode_x", "https://github.com/camiicode"],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "hello@tomanote.app",
          "contactType": "customer service"
        }
      }
    </script>

    {/* === HOWTO SCHEMA === */}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to use TomaNote",
        "description": "Learn how to use TomaNote - a free, private, and offline notepad.",
        "step": [
          {
            "@type": "HowToStep",
            "name": "Open the app",
            "text": "Navigate to https://tomanote.app in your browser."
          },
          {
            "@type": "HowToStep",
            "name": "Create a note",
            "text": "Click the + button to create a new tab and start writing."
          },
          {
            "@type": "HowToStep",
            "name": "Write and auto-save",
            "text": "Start typing in the editor. Your notes are automatically saved in real-time - no need to click save."
          },
          {
            "@type": "HowToStep",
            "name": "No account needed",
            "text": "TomaNote works completely anonymously. No registration, no email, no password required."
          },
          {
            "@type": "HowToStep",
            "name": "Rename a tab",
            "text": "Double-click on the tab title to rename it."
          },
          {
            "@type": "HowToStep",
            "name": "Pin tabs",
            "text": "Right-click on a tab and select 'Pin' to keep it at the beginning of your tabs."
          },
          {
            "@type": "HowToStep",
            "name": "Change theme",
            "text": "Open Settings (gear icon) > Appearance to choose between dark, light, or colorful themes."
          },
          {
            "@type": "HowToStep",
            "name": "Change font",
            "text": "Go to Settings > Typography to select from 6 different fonts: Inter, Poppins, Open Sans, Raleway, Roboto, or Montserrat."
          },
          {
            "@type": "HowToStep",
            "name": "Adjust font size",
            "text": "In Settings > Typography, choose between base, medium, or large text sizes."
          },
          {
            "@type": "HowToStep",
            "name": "Change language",
            "text": "Open Settings > Language to switch between English and Spanish."
          },
          {
            "@type": "HowToStep",
            "name": "Install on mobile",
            "text": "On mobile, tap Share > Add to Home Screen to install TomaNote as a native app."
          }
        ]
      }
    </script>
  </head>

  <body id="body" class="h-lvh relative">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <EmptyState />
    <main id="main-content" role="main">
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.5rem 1rem;
    background: #1a1a1a;
    color: #ffffff;
    font-size: 0.875rem;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    transition: top 0.15s ease;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
