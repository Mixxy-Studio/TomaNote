---
// Styles
import "./bottom-bar.scss";

// Components
import BottomBarTab from "./components/BottomBarTab.astro";
import BottomBarSubmenu from "./components/BottomBarSubmenu.astro";

// i18n
import { getLang, useTranslations } from "../../i18n/utils";
const t = useTranslations(getLang());

const contentItems = [
  { action: "redo", iconName: "redo", tooltip: t("context-menu.redo"), className: "tn-redo" },
  { action: "undo", iconName: "undo", tooltip: t("context-menu.undo"), className: "tn-undo" },
  { action: "copy", iconName: "copy", tooltip: t("context-menu.copy"), className: "tn-copy" },
  { action: "paste", iconName: "paste", tooltip: t("context-menu.paste"), className: "tn-paste" },
];

const fontItems = [
  { action: "bold", iconName: "bold", tooltip: t("context-menu.bold"), className: "tn-bold" },
  { action: "underline", iconName: "underline", tooltip: t("context-menu.underline"), className: "tn-under" },
  { action: "italic", iconName: "italic", tooltip: t("context-menu.italic"), className: "tn-italic" },
];

const tabItems = [
  { action: "pin-tab", iconName: "pin", tooltip: t("context-menu.pin-tab"), className: "tn-pin" },
  { action: "edit-name-tab", iconName: "edit", tooltip: t("context-menu.edit-name-tab"), className: "tn-edit" },
  { action: "delete-tab", iconName: "delete", tooltip: t("context-menu.delete-tab"), className: "tn-delete" },
];
---

<nav id="bottom-bar" class="tn-bottom-bar hidden md:hidden" style="bottom: var(--bb-bottom, 0px); padding-bottom: var(--bb-pb, 0rem);">
  <div class="tn-bottom-bar-submenu-container" id="bottom-bar-submenu-container">
    <BottomBarSubmenu id="submenu-content" items={contentItems} />
    <BottomBarSubmenu id="submenu-font" items={fontItems} />
    <BottomBarSubmenu id="submenu-tab" items={tabItems} />
  </div>

  <div class="tn-bottom-bar-row">
    <BottomBarTab iconName="clipboard" action="content" tooltip={t("context-menu.content")} hasSubmenu={true} />
    <BottomBarTab iconName="font" action="font" tooltip={t("context-menu.font")} hasSubmenu={true} iconStrokeWidth="10" />
    <BottomBarTab iconName="tab" action="tab" tooltip={t("context-menu.tab")} hasSubmenu={true} />
    <BottomBarTab iconName="search" action="search" tooltip={t("context-menu.search")} />
    <BottomBarTab iconName="settings" action="settings" tooltip={t("context-menu.settings")} />
    <button id="bottom-bar-create-tab" class="tn-bottom-bar-btn flex flex-col items-center justify-center gap-0.5 flex-1 py-2 cursor-pointer transition-colors duration-200" aria-label={t("context-menu.new-tab")} type="button">
      <span class="tn-bottom-bar-create-icon flex justify-center items-center size-6 rounded-full bg-(--tn-theme-contrast) text-(--tn-neutral-tertiary-color)">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      </span>
    </button>
  </div>
</nav>
