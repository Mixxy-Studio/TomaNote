---
// RoadmapTab.astro
import { getLang } from "../../i18n/utils";
import Icon from "../../components/icons/Icon.astro";
import roadmapData from "./roadmap-data.json";
import RoadmapColumn from "./RoadmapColumn.astro";

const lang = getLang();

// Filtrar versiones que se muestran en el tab (solo prev, current, next)
const visibleVersions = roadmapData.versions.filter((v) => v.showInTab !== false);

// Ordenar: previous, current, next (orden visual: Anterior → Actual → Próximo)
const currentV = visibleVersions.find((v) => v.isCurrent);
const previousV = visibleVersions.find((v) => v.type === "previous");
const nextV = visibleVersions.find((v) => v.isNext);
const orderedVersions = [previousV, currentV, nextV].filter((v): v is NonNullable<typeof v> => v !== undefined);

// Todas las versiones antiguas para el historial completo
const oldVersions = roadmapData.versions.filter((v) => v.isOld);
---

<div class="settings-tab hidden [&.active]:block" id="roadmap-tab">
  <div class="settings-header mb-[24px]! text-center">
    <h3><u>Roadmap</u></h3>
  </div>
  <hr />

  <div class="settings-body">
    <div class="p-4!">
      {/* Versiones visibles en el tab */}
      <div class="grid 2xl:grid-cols-3 gap-4! items-start">
        {orderedVersions.map((version) => <RoadmapColumn version={version} lang={lang} />)}
      </div>
    </div>
  </div>
</div>
