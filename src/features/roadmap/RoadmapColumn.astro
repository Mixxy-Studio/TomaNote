---
// RoadmapColumn.astro
export interface Props {
  version: {
    id: string;
    type: string;
    versionNumber: string;
    date: string;
    isCurrent: boolean;
    isNext: boolean;
    isOld?: boolean;
    showInTab?: boolean;
    items: {
      es: Array<{ summary: string; description: string }>;
      en: Array<{ summary: string; description: string }>;
    };
  };
  lang: string;
  isHistorical?: boolean;
}

const { version, lang, isHistorical = false } = Astro.props;
const items = version.items[lang as keyof typeof version.items];

// Clases adaptadas para versiones históricas
const getColumnClasses = () => {
  if (isHistorical) {
    return "rounded-xl overflow-hidden bg-(--tn-theme-secondary)/50 border border-(--tn-theme-accent)/20 opacity-75";
  }

  const baseClasses = "rounded-xl overflow-hidden hover:shadow transition-all! duration-300! ease-in-out! cursor-default hover:scale-101";

  if (version.isCurrent) {
    return `${baseClasses} bg-(--tn-theme-contrast)/20 border-2 border-(--tn-theme-contrast)`;
  }

  if (version.isNext) {
    return `${baseClasses} bg-(--tn-theme-secondary) border border-(--tn-theme-accent)/30 opacity-75`;
  }

  return `${baseClasses} bg-(--tn-theme-secondary) border border-(--tn-theme-accent)/30`;
};

const getBadgeClasses = () => {
  if (isHistorical) {
    return "text-[10px] font-medium text-(--tn-color-text)/40 uppercase tracking-widest";
  }

  if (version.isCurrent) {
    return "inline-block text-[11px] font-medium bg-(--tn-theme-contrast) text-(--tn-neutral-tertiary-color) px-2! py-0.5! rounded-md mb-1.5!";
  }

  return "text-[11px] font-medium text-(--tn-color-text)/50 uppercase tracking-widest";
};

const getBadgeText = () => {
  if (isHistorical) return `v${version.versionNumber}`;
  if (version.isCurrent) return "ACTUAL";
  if (version.isNext) return "PRÓXIMO";
  return "ANTERIOR";
};

const getBadgeI18nKey = () => {
  if (isHistorical) return "";
  if (version.isCurrent) return "roadmap.badge.current";
  if (version.isNext) return "roadmap.badge.next";
  return "roadmap.badge.previous";
};

// Languages
import { getLang, useTranslations } from "../../i18n/utils";
const currentLang = getLang();
const t = useTranslations(currentLang);

// Icons
import Icon from "../../components/icons/Icon.astro";
---

<div class={getColumnClasses()}>
  <div class={`px-4! py-3! border-b ${version.isCurrent && !isHistorical ? "border-(--tn-theme-contrast)/30" : "border-(--tn-theme-accent)/30"}`}>
    <span class={getBadgeClasses()} data-i18n={getBadgeI18nKey()}>{getBadgeText()}</span>
    <p class="mt-1! text-[15px] font-medium text-(--tn-color-text)">{version.versionNumber}</p>
    <p class="mt-0.5! text-xs text-(--tn-color-text)/50">{version.date}</p>
  </div>

  <div class="px-4! py-3!">
    <ul class="flex flex-col gap-1! list-none! p-0! m-0!">
      {
        items.map((item, index) => (
          <li class={`${index === items.length - 1 ? "" : "border-b border-(--tn-theme-accent)/20"} ${version.isNext && !isHistorical ? "last:border-0" : "last:border-0"}`}>
            <details class="group">
              <summary class={`flex items-center gap-2! py-2! cursor-pointer list-none text-[13px] ${version.isCurrent && !isHistorical ? "text-(--tn-color-text)" : "text-(--tn-color-text)/70"} pl-3! border-l-2 ${version.isCurrent && !isHistorical ? "border-(--tn-theme-contrast)" : "border-(--tn-theme-accent)/40"} ${version.isNext && !isHistorical ? "italic" : ""}`}>
                <Icon name="chevronright" className="text-[10px] text-(--tn-color-text)/40 group-open:rotate-90 transition-transform! duration-200! size-3!" />
                <span data-i18n={`roadmap.${version.id}.${index}.summary`}>{item.summary}</span>
              </summary>
              <p data-i18n={`roadmap.${version.id}.${index}.description`} class={`text-[12px] ${version.isCurrent && !isHistorical ? "text-(--tn-color-text)/60" : "text-(--tn-color-text)/50"} pl-3! pr-2! pb-2! mt-0! mb-0! leading-relaxed ${version.isNext && !isHistorical ? "italic" : ""}`}>
                {item.description}
              </p>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</div>
