---
// Appearance.astro - Settings Modal - Appearance Tab
---

<section id="appearance-tab" class="tn-appearance-tab settings-tab hidden [&.active]:block">
  <div class="settings-header">
    <h3 data-i18n="appearance.main-title"></h3>
  </div>
  <hr />

  <div class="settings-body">
    {/* Seleccion de color de tema */}
    <div class="grid lg:grid-cols-3 gap-4">
      <div class="col-span-1">
        <h3 class="text-(--tn-theme-accent) font-bold" data-i18n="appearance.first-option"></h3>
        <p data-i18n="appearance.first-option-description">Pick your favorite theme</p>
      </div>
      <div class="col-span-2">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-2 xl:grid-cols-3 gap-4!">
          <div class="group">
            <input type="radio" name="themeColor" id="theme-color-dark" class="hidden peer" checked />
            <label for="theme-color-dark" aria-label="Dark Theme">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </label>
          </div>
          <div class="group">
            <input type="radio" name="themeColor" id="theme-color-light" class="hidden peer" />
            <label for="theme-color-light" aria-label="Light Theme">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </label>
          </div>
          <div class="group">
            <input type="radio" name="themeColor" id="theme-color-rose" class="hidden peer" />
            <label for="theme-color-rose" aria-label="Rose Theme">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </label>
          </div>
          <div class="group">
            <input type="radio" name="themeColor" id="theme-color-aqua" class="hidden peer" />
            <label for="theme-color-aqua" aria-label="Aqua Theme">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </label>
          </div>
          <div class="group">
            <input type="radio" name="themeColor" id="theme-color-forest" class="hidden peer" />
            <label for="theme-color-forest" aria-label="Forest Theme">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </label>
          </div>
          <div class="group">
            <input type="radio" name="themeColor" id="theme-color-orbit" class="hidden peer" />
            <label for="theme-color-orbit" aria-label="Orbit Theme">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </label>
          </div>
        </div>
      </div>
    </div>

    {/* Seleccion de Lenguaje */}
    <div class="grid lg:grid-cols-3 gap-4 pt-10!">
      <div class="col-span-1">
        <h3 class="text-(--tn-theme-accent) font-bold" data-i18n="lang.main-title"></h3>
        <p data-i18n="lang.main-subtitle"></p>
      </div>
      <div class="col-span-2">
        <select id="lang-select" class="tn-lang-select w-full py-2.5! px-3! rounded-sm border-2 border-(--tn-theme-accent) bg-(--tn-theme-secondary) text-(--color-accent)! text-normal cursor-pointer transition-all hover:border-(--tn-theme-accent) focus:text-(--color-accent)! focus:outline-0 focus:border-(--tn-theme-contrast)">
          <option class="text-(--color-text)/75" data-i18n="lang.option-en_us" value="en"></option>
          <option class="text-(--color-text)/75" data-i18n="lang.option-es_co" value="es"></option>
        </select>
      </div>
    </div>

    {/* Seleccion de anchura del documento */}
    <div class="grid lg:grid-cols-3 gap-4 pt-10!">
      {/* Titulo de la seccion */}
      <div class="col-span-1">
        <h3 class="text-(--tn-theme-accent) font-bold" data-i18n="width.main-title"></h3>
        <p data-i18n="width.main-subtitle"></p>
      </div>

      <div class="col-span-2">
        <div class="grid grid-cols-2 sm:grid-cols-1 lg:grid-cols-1 xl:grid-cols-4 gap-4!">
          {/* By Default */}
          <div class="col-span-1">
            <div class="desc pb-2">
              <p class="text-(--tn-theme-accent) text-center" data-i18n="width.option-default"></p>
            </div>
            <div class="group">
              <input type="radio" name="editor-width" id="width-default" class="sr-only peer" checked />
              <label for="width-default">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 250" width="100%" height="100%">
                  <rect width="200" height="250" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2"></rect>
                  <rect x="16" y="20" width="168" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="16" y="36" width="168" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="16" y="52" width="130" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="16" y="76" width="168" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="16" y="92" width="168" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="16" y="108" width="90" height="6" rx="3" fill="#cbd5e1"></rect>
                </svg>
              </label>
            </div>
          </div>
          {/* Stretched */}
          <div class="col-span-1">
            <div class="desc pb-2">
              <p class="text-(--tn-theme-accent) text-center" data-i18n="width.option-stretch"></p>
            </div>
            <div class="group">
              <input type="radio" name="editor-width" id="width-stretch" class="sr-only peer" />
              <label for="width-stretch">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 230" width="100%" height="100%">
                  <rect width="200" height="230" rx="8" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2"></rect>
                  <rect x="40" y="20" width="120" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="40" y="36" width="120" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="40" y="52" width="90" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="40" y="76" width="120" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="40" y="92" width="120" height="6" rx="3" fill="#cbd5e1"></rect>
                  <rect x="40" y="108" width="70" height="6" rx="3" fill="#cbd5e1"></rect>
                </svg>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Seleccion de fondo de diseño del documento */}
    <div class="grid lg:grid-cols-3 gap-4 pt-10!">
      {/* Titulo de la seccion */}
      <div class="col-span-1">
        <h3 class="text-(--tn-theme-accent) font-bold" data-i18n="ppr-bg.main-title"></h3>
        <p data-i18n="ppr-bg.main-subtitle"></p>
      </div>

      <div class="col-span-2">
        <div class="grid grid-cols-2 sm:grid-cols-1 lg:grid-cols-1 xl:grid-cols-4 gap-4!">
          {/* Select Flat */}
          <div class="col-span-1">
            <div class="desc pb-2">
              <p class="text-(--tn-theme-accent) text-center" data-i18n="ppr-bg.option-flat"></p>
            </div>
            <div class="group">
              <input type="radio" name="editor-bg" id="bg-flat" class="sr-only peer" checked />
              <label for="bg-flat">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 250" width="100%" height="100%">
                  <rect width="200" height="250" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5"></rect>
                </svg>
              </label>
            </div>
          </div>
          <div class="col-span-1">
            <div class="desc pb-2">
              <p class="text-(--tn-theme-accent) text-center" data-i18n="ppr-bg.option-underline"></p>
            </div>
            <div class="group">
              <input type="radio" name="editor-bg" id="bg-underline" class="sr-only peer" />
              <label for="bg-underline">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 250" width="100%" height="100%">
                  <rect width="200" height="250" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5"></rect>
                  <line x1="16" y1="24" x2="184" y2="24" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="44" x2="184" y2="44" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="64" x2="184" y2="64" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="84" x2="184" y2="84" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="104" x2="184" y2="104" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="144" x2="184" y2="144" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="164" x2="184" y2="164" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="184" x2="184" y2="184" stroke="#cbd5e1" stroke-width="2"></line>
                  <line x1="16" y1="204" x2="184" y2="204" stroke="#cbd5e1" stroke-width="2"></line>
                </svg>
              </label>
            </div>
          </div>
          <div class="col-span-1">
            <div class="desc pb-2">
              <p class="text-(--tn-theme-accent) text-center" data-i18n="ppr-bg.option-grid"></p>
            </div>
            <div class="group">
              <input type="radio" name="editor-bg" id="bg-grid" class="sr-only peer" />
              <label for="bg-grid">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 250" width="100%" height="100%">
                  <defs>
                    <pattern id="grid-pattern-clean" width="20" height="20" patternUnits="userSpaceOnUse">
                      <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#cbd5e1" stroke-width="2"></path>
                    </pattern>
                  </defs>
                  <rect width="200" height="250" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="2"></rect>
                  <rect x="10" y="10" width="180" height="230" fill="url(#grid-pattern-clean)"></rect>
                </svg>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
