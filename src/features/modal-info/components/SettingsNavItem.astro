---
// Astro Props
interface Props {
  tabId: string;
  iconName: string;
  labelKey: string;
  className: string;
}

const { tabId, iconName, labelKey, className } = Astro.props;

// Icons
import Icon from "../../../components/icons/Icon.astro";
---

<button class={`nav-item ${className} bg-transparent border-0 w-auto text-start cursor-pointer lg:w-full hover:bg-(--tn-theme-primary-dark)/25 inline-flex items-center rounded-sm text-(--color-text) lg:flex [&.active]:bg-(--tn-theme-secondary)! [&.active]:text-(--color-text)! text-sm! py-[5px]! px-[10px]! my-[4px]! mx-0! transition-colors duration-200`} data-tab={tabId}>
  <span class="icon mr-[12px]!">
    <Icon name={iconName} className="size-1 md:size-6" />
  </span>
  <span data-i18n={labelKey}></span>
</button>