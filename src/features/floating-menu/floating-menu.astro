---
// Styles
import "./floating-menu.scss";

// Components
import CreateTab from "../../components/Createtab.astro";
import MainToolsButton from "./components/MainToolsButton.astro";
import FloatingButtonGroup from "./components/FloatingButtonGroup.astro";
import FloatingButton from "./components/FloatingButton.astro";

// i18n
import { getLang, useTranslations } from "../../i18n/utils";
const t = useTranslations(getLang());

const contentButtons = [
  { action: "redo", iconName: "redo", tooltip: t("context-menu.redo"), className: "tn-redo" },
  { action: "undo", iconName: "undo", tooltip: t("context-menu.undo"), className: "tn-undo" },
  { action: "copy", iconName: "copy", tooltip: t("context-menu.copy"), className: "tn-copy" },
  { action: "paste", iconName: "paste", tooltip: t("context-menu.paste"), className: "tn-paste" },
];

const fontButtons = [
  { action: "bold", iconName: "bold", tooltip: t("context-menu.bold"), className: "tn-bold" },
  { action: "underline", iconName: "underline", tooltip: t("context-menu.underline"), className: "tn-under" },
  { action: "italic", iconName: "italic", tooltip: t("context-menu.italic"), className: "tn-italic" },
];

const tabButtons = [
  { action: "pin-tab", iconName: "pin", tooltip: t("context-menu.pin-tab"), className: "tn-pin" },
  { action: "edit-name-tab", iconName: "edit", tooltip: t("context-menu.edit-name-tab"), className: "tn-edit" },
  { action: "delete-tab", iconName: "delete", tooltip: t("context-menu.delete-tab"), className: "tn-delete" },
];
---

<nav class="tn-navbar" id="floating-nav" style="bottom: var(--nav-bottom, 1rem); padding-bottom: var(--nav-pb, 0rem);">
  <div dir="rtl" class="tn-navbar-btns tn-navbar-checked flex flex-col-reverse items-center justify-between gap-1 h-auto">
    <CreateTab />

    <MainToolsButton />

    <div class="max-h-0 relative overflow-hidden peer-checked/menu:overflow-visible peer-checked/menu:max-h-[300px]! max-w-[60px] transition-all duration-300 ease-in-out flex flex-col items-center justify-center gap-1">
      {/* Content Group */}
      <FloatingButtonGroup id="tn-navbar__content" radioName="options" radioId="tn-open-options__content" iconName="clipboard" buttons={contentButtons} iconStrokeWidth="1.5" />

      {/* Font group */}
      <FloatingButtonGroup id="tn-navbar__font" radioName="options" radioId="tn-open-options__font" iconName="font" buttons={fontButtons} iconStrokeWidth="10" />

      {/* Tab Group */}
      <FloatingButtonGroup id="tn-navbar__tab" radioName="options" radioId="tn-open-options__tab" iconName="tab" buttons={tabButtons} iconStrokeWidth="1.5" />

      {/* Individual Settings button */}
      <FloatingButton action="settings" iconName="settings" tooltip={t("context-menu.settings")} className="tn-setting border-(--tn-theme-contrast)! p-4! bg-(--tn-theme-secondary)" onClick="event.preventDefault(); document.querySelector('dialog#info-notepad').showModal()" />
    </div>
  </div>
</nav>