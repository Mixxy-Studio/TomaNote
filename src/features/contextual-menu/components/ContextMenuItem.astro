---
// Astro Props
interface Props {
  action: string;
  iconName: string;
  labelKey: string;
  shortcut?: string;
  requiresSelection?: boolean;
}

const { action, iconName, labelKey, shortcut, requiresSelection = false } = Astro.props;

// Icons
import Icon from "../../../components/icons/Icon.astro";
---

<div class="context-menu__item group context-menu__item:hover py-2! px-3! cursor-pointer flex! justify-start items-center hover:bg-(--tn-neutral-tertiary-color)/20 hover:text-(--tn-theme-contrast) text-md" data-action={action} data-requires-selection={requiresSelection ? "true" : undefined}>
  <Icon name={iconName} className="size-1 text-(--tn-theme-contrast) mr-1!" />

  {
    shortcut ? (
      <div class="flex justify-between items-center w-full">
        <span class="font-semibold text-(--tn-neutral-tertiary-color)" data-i18n={labelKey} />
        <span class="font-black shortcut group-hover:text-(--tn-theme-primary) group-hover:opacity-80 transition-opacity ml-auto! text-(--tn-theme-contrast) opacity-[0.6] py-0.5 px-1 text-xs!">{shortcut}</span>
      </div>
    ) : (
      <span class="font-semibold text-(--tn-neutral-tertiary-color)" data-i18n={labelKey} />
    )
  }
</div>
