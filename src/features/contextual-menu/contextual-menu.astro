---
// Styles
import "./contextual-menu.scss";

// Components
import ContextMenuItem from "./components/ContextMenuItem.astro";
import ContextMenuSeparator from "./components/ContextMenuSeparator.astro";

const editItems = [
  { action: "copy", iconName: "copy", labelKey: "context-menu.copy", shortcut: "Ctrl + C", requiresSelection: true },
  { action: "cut", iconName: "cut", labelKey: "context-menu.cut", shortcut: "Ctrl + X", requiresSelection: true },
  { action: "paste", iconName: "paste", labelKey: "context-menu.paste", shortcut: "Ctrl + V" },
];

const formatItems = [
  { action: "bold", iconName: "bold", labelKey: "context-menu.bold", shortcut: "Ctrl + B", requiresSelection: true },
  { action: "italic", iconName: "italic", labelKey: "context-menu.italic", shortcut: "Ctrl + I", requiresSelection: true },
  { action: "underline", iconName: "underline", labelKey: "context-menu.underline", shortcut: "Ctrl + U", requiresSelection: true },
];

const historyItems = [
  { action: "undo", iconName: "undo", labelKey: "context-menu.undo", shortcut: "Ctrl + Z" },
  { action: "redo", iconName: "redo", labelKey: "context-menu.redo", shortcut: "Ctrl + Y" },
];

const tabItems = [{ action: "pin-tab", iconName: "pin", labelKey: "context-menu.pin-tab" }];
---

<div id="context-menu" class="context-menu hidden fixed bg-(--tn-theme-primary) border border-(--tn-theme-contrast) rounded-lg shadow-2xl z-50 min-w-[200px] w-auto">
  {/* Edition */}
  {editItems.map((item) => <ContextMenuItem action={item.action} iconName={item.iconName} labelKey={item.labelKey} shortcut={item.shortcut} requiresSelection={item.requiresSelection} />)}

  <ContextMenuSeparator variant="thin" />

  {/* Format */}
  {formatItems.map((item) => <ContextMenuItem action={item.action} iconName={item.iconName} labelKey={item.labelKey} shortcut={item.shortcut} requiresSelection={item.requiresSelection} />)}

  <ContextMenuSeparator variant="thin" />

  {/* History */}
  {historyItems.map((item) => <ContextMenuItem action={item.action} iconName={item.iconName} labelKey={item.labelKey} shortcut={item.shortcut} />)}

  <ContextMenuSeparator variant="thin" />

  {/* Tabs */}
  {tabItems.map((item) => <ContextMenuItem action={item.action} iconName={item.iconName} labelKey={item.labelKey} />)}
</div>
