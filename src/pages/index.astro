---
// Layouts
import Layout from "../layouts/Layout.astro";

// Features
import FloatingMenu from "../features/floating-menu/floating-menu.astro";
import ContextualMenu from "../features/contextual-menu/contextual-menu.astro";
import Modalsinfo from "../features/modal-info/modal-info.astro";
import CloseTabConfirmation from "../features/close-tab-confirmation/close-tab-confirmation.astro";
---

<Layout>
  <CloseTabConfirmation />
  <div dir="ltr" class="tab-list flex flex-row justify-start items-start w-full h-full max-w-[100dvw] overflow-x-auto z-[999]">
    <span id="tab-list-anchor" class="hidden"></span>
  </div>

  <Modalsinfo />
  <ContextualMenu />
  <FloatingMenu />
</Layout>

<script>
  import { initNotepad } from "../lib/scripts/entry.js";

  // Inicializar de forma segura con timeout
  document.addEventListener("DOMContentLoaded", () => {
    setTimeout(() => {
      initNotepad().catch((error) => {
        console.error("Error en sistema modular:", error);
      });
    }, 100); // Pequeño delay para asegurar que el DOM está listo
  });
</script>
