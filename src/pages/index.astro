---
// Layouts
import Layout from "../layouts/Layout.astro";

// Components
import Createtab from "../components/Createtab.astro";
import DarklightButton from "../components/DarklightButton.astro";
import InfoButton from "../components/InfoButton.astro";
import Modalsinfo from "../components/Modalsinfo.astro";
import ContextualMenu from "../components/ContextualMenu.astro";
---

<Layout>
  
  <div dir="ltr" class="tab-list">
    
    <Createtab />
    <DarklightButton />
    <InfoButton />

  </div>
  
  <Modalsinfo />
  <ContextualMenu />

</Layout>

<!-- 
  ESTRATEGIA SEGURA:
  1. Mantener el script inline existente (comentado pero funcional)
  2. Agregar el nuevo sistema modular gradualmente
  3. Poder volver fácilmente si hay problemas
-->

<!-- SCRIPT INLINE EXISTENTE (lo mantendremos por ahora como backup) -->
<!-- <script is:inline>
// --- BACKUP: Código original ---
