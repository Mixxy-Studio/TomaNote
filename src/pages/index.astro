---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  
  <div dir="ltr" class="tab-list">
    <button id="create-tab">+</button>
    <div class="options-tab">
      <input type="checkbox" name="dark-mode-toggle" id="dark-mode-toggle">
      <label for="dark-mode-toggle"></label>
    </div>
    <div class="info-tab">
      <button onclick="event.preventDefault(); document.querySelector('dialog#info-notepad').showModal()" id="open-modal-info">i</button>
    </div>
    
  </div>

  <section id="modals">
    <dialog id="info-notepad" class="info">
      <div class="info-container">
        <div class="info-row">
          <div class="info-content">
            <div class="info-content__header">
              <h1>Bloc de Notas Online Gratuito</h1>
              <p>
                Este es un bloc de notas gratuito, sencillo y básico, que puedes
                usar directamente en tu navegador. Todos los cambios se guardan
                en el almacenamiento local del navegador, pero ten en cuenta que
                al recargar sin caché, se perderá la información. Haz un
                respaldo de tus notas antes de recargar.
              </p>
            </div>
            <div class="info-content__main">
              <h4>Funcionalidades</h4>
              <ol>
                <li>Menu Contextual</li>
                <li>
                  Guardado Automático: Los cambios se guardan en el Local
                  Storage.
                </li>
                <li>
                  Gestión de Pestañas
                  <ul>
                    <li>Editar nombre de pestañas</li>
                    <li>Crear nuevas pestañas</li>
                    <li>Eliminar pestañas existentes</li>
                  </ul>
                </li>
              </ol>
            </div>
            <div class="info-content__footer">
              <div
                class="info-content__footer--left info-content__footer--column"
              >
                <a
                  href="#"
                  onclick="event.preventDefault(); document.querySelector('dialog#info-license').showModal();"
                  >Licencia</a
                >
              </div>
              <div
                class="info-content__footer--center info-content__footer--column"
              >
                <a
                  href="#"
                  onclick="event.preventDefault(); document.querySelector('dialog#info-terms').showModal();"
                  >Terminos de Uso</a
                >
              </div>
              <div
                class="info-content__footer--right info-content__footer--column"
              >
                <form method="dialog">
                  <button>Cerrar</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </dialog>

    <dialog id="info-license" class="info">
      <form method="dialog">
        <button>X</button>
      </form>
      <h3>Licencia GNU Affero General Public License (AGPL) v3.0</h3>
      <p>
        Este software está licenciado bajo la GNU Affero General Public License
        (AGPL) v3.0. La licencia AGPL v3.0 garantiza a los usuarios la libertad
        de usar, estudiar, modificar y distribuir el software, bajo las
        siguientes condiciones:
      </p>
      <ol>
        <li>
          <p>
            <strong>Libre Uso:</strong> El software puede ser utilizado para cualquier
            propósito, sin restricciones.
          </p>
        </li>
        <li>
          <p>
            <strong>Modificación:</strong> Los usuarios pueden modificar el software
            y distribuir las versiones modificadas.
          </p>
        </li>
        <li>
          <p>
            <strong>Distribución:</strong> Cualquier copia del software, ya sea en
            su forma original o modificada, debe incluir la misma licencia AGPL v3.0.
          </p>
        </li>
      </ol>
      <h4>Cláusula Adicional: Restricción de Uso Comercial</h4>
      <p>
        Este software está licenciado bajo la GNU Affero General Public License
        (AGPL) v3.0. Sin embargo, se incluye la siguiente cláusula adicional:
      </p>
      <p>
        <strong>Uso Comercial Restringido:</strong>Se prohíbe la
        comercialización directa o indirecta de este software, incluyendo pero
        no limitado a la venta, arrendamiento, sublicenciamiento, o cualquier
        otro uso con fines comerciales, sin el consentimiento expreso y por
        escrito del titular original de los derechos de autor. Esta restricción
        no afecta los derechos de los usuarios a modificar, mejorar o
        redistribuir el software siempre que dichas actividades no impliquen un
        uso comercial.
      </p>
      <p>
        Para obtener permisos específicos relacionados con el uso comercial, por
        favor contacta al titular de los derechos de autor.
      </p>
    </dialog>

    <dialog id="info-terms" class="info">
      <form method="dialog">
        <button>X</button>
      </form>
      <h3>Términos y Advertencias para el Uso del Bloc de Notas</h3>
      <ol>
        <li>
          <p>
            <strong>Límite de Almacenamiento <br /><br /></strong> Este Bloc de Notas
            utiliza el LocalStorage de tu navegador para guardar la información.
            Aunque el límite de almacenamiento es de 5 MB, te recomiendo no almacenar
            grandes volúmenes de texto. Ten en cuenta que el almacenamiento en el
            navegador es limitado y puede verse afectado si guardas grandes cantidades
            de información. Si alcanzas el límite, podrías perder datos, por lo que
            sugerimos realizar copias de seguridad regularmente.
          </p>
        </li>
        <li>
          <p>
            <strong>Seguridad de la Información <br /><br /></strong> La información
            que guardas en este Bloc de Notas no está encriptada y se almacena en
            el LocalStorage de tu navegador, lo cual no garantiza su seguridad. Te
            recomiendo no guardar información sensible o privada en esta herramienta,
            ya que podría ser vulnerable a accesos no autorizados si otros usuarios
            tienen acceso a tu dispositivo o navegador.
          </p>
        </li>
        <li>
          <p>
            <strong>Precaución con la URL <br /><br /></strong> Asegúrate de que
            estás utilizando una URL confiable y segura al acceder al Bloc de Notas.
            Evita acceder desde enlaces sospechosos o en redes públicas no seguras,
            ya que podrías exponerte a ataques de suplantación de identidad (phishing)
            o robo de datos. Te recordamos que el equipo de desarrollo no se responsabiliza
            por la pérdida de datos debido a usos inapropiados de la herramienta
            o acceso no seguro.
          </p>
        </li>
      </ol>
    </dialog>
  </section>

  <div id="context-menu" class="context-menu">
    <div class="context-menu__item" data-action="copy" data-requires-selection="true">
      <span>Copiar</span>
      <span class="shortcut">Ctrl + C</span>
    </div>
    <div class="context-menu__item" data-action="cut" data-requires-selection="true">
      <span>Cortar</span>
      <span class="shortcut">Ctrl + X</span>
    </div>
    <div class="context-menu__item" data-action="paste">
      <span>Pegar</span>
      <span class="shortcut">Ctrl + V</span>
    </div>
    <div class="context-menu__separator"></div>
    <div class="context-menu__item" data-action="bold" data-requires-selection="true">
      <span>Negrita</span>
      <span class="shortcut">Ctrl + B</span>
    </div>
    <div class="context-menu__item" data-action="italic" data-requires-selection="true">
      <span>Cursiva</span>
      <span class="shortcut">Ctrl + I</span>
    </div>
    <div class="context-menu__item" data-action="underline" data-requires-selection="true">
      <span>Subrayado</span>
      <span class="shortcut">Ctrl + U</span>
    </div>
    <div class="context-menu__separator"></div>
    <div class="context-menu__item" data-action="undo">
      <span>Deshacer</span>
      <span class="shortcut">Ctrl + Z</span>
    </div>
    <div class="context-menu__item" data-action="redo">
      <span>Rehacer</span>
      <span class="shortcut">Ctrl + Y</span>
    </div>
  </div>

</Layout>

<style lang="scss" is:global is:inline>
  :root.light-mode {
    --color-background: #ffffff;
    --color-secondary-background: #f0f0f0;
    --color-primary: #333333;
    --color-secondary: #e0e0e0;
    --color-button-background: #e0e0e0;
    --color-button-delete: #dc3545;
    --color-button-hover: #d0d0d0;
    --color-scrollbar-thumb: #b0b0b0;
    --color-scrollbar-track: #e0e0e0;
    --color-scrollbar-hover: #a0a0a0;
    --sb-track-color: #e0e0e0;
    --sb-thumb-color: #b0b0b0;
  }
  .options-tab input:checked + label {
    background-color: #e0e0e0;
  }
  .options-tab input:checked + label::after {
    background: linear-gradient(180deg, #ccc, #e0e0e0);
  }
  .options-tab label {
    box-shadow:
      inset 0px 5px 15px rgba(0, 0, 0, 0.1),
      inset 0px -5px 15px rgba(255, 255, 255, 0.5);
  }

  :root {
    --font-size-base: 1rem;
    --font-size-large: 1.5rem;
    --font-family-mono: "Source Code Pro", monospace;
    --padding-base: 10px;
    --padding-block: 1rem;
    --margin-base: 1rem;
    --border-radius: 5px;
    --border-radius-small: 4px;
    --box-shadow-none: none;
    --scrollbar-width: 2px;
    --scrollbar-height: 2px;
    --sb-track-color: #2d2d2d;
    --sb-thumb-color: #676767;
    --sb-size: 18px;
  }
  @media (prefers-color-scheme: dark) {
    html {
      --color-background: #1c1b22;
      --color-secondary-background: #141414;
      --color-primary: #fff;
      --color-secondary: #2d2d2d;
      --color-button-background: #3a3939;
      --color-button-delete: #dc3545;
      --color-button-hover: #494949;
      --color-scrollbar-thumb: #888;
      --color-scrollbar-track: #333;
      --color-scrollbar-hover: #555;
    }
  }
  .source-code-pro-font {
    font-family: "Source Code Pro", monospace;
    font-optical-sizing: auto;
    font-weight: 100;
    font-style: normal;
  }
  body {
    margin: 0;
    padding: var(--padding-base);
    color: var(--color-primary);
    background-color: var(--color-background);
    width: 100%;
    height: auto;
    min-height: 100vh;
    overflow: hidden;
    font-family: var(--font-family-mono);
  }
  body img {
    max-width: 500px;
  }
  body button {
    cursor: pointer;
  }
  .code-block {
    background-color: var(--color-secondary-background);
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-family-mono);
    padding: var(--padding-block);
    margin-bottom: var(--margin-base);
    border-radius: var(--border-radius-small);
  }
  .tab-list {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
    max-width: 99%;
    overflow-x: auto;
  }
  .options-tab {
    margin-left: auto;
    padding-left: 50px;
  }
  .options-tab input {
    width: 0;
    height: 0;
    visibility: hidden;
    display: none;
  }
  .options-tab input:checked + label {
    background-color: var(--color-background);
    transition: ease-in-out 0.3s all;
  }
  .options-tab input:checked + label::after {
    left: 45px;
    transform: translateX(-100%);
    background: linear-gradient(180deg, #777, var(--color-secondary-background));
    transition: ease-in-out 0.3s all;
  }
  .options-tab label:active::after {
    width: 25px;
    transition: ease-in-out 0.3s all;
  }
  .options-tab label {
    width: 50px;
    height: 25px;
    position: relative;
    display: block;
    background: var(--color-secondary-background);
    border-radius: 50px;
    box-shadow:
      inset 0px 5px 15px rgba(0, 0, 0, 0.4),
      inset 0px -5px 15px rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: ease-in-out 0.3s all;
  }
  .options-tab label::after {
    content: "";
    width: 20px;
    height: 20px;
    position: absolute;
    top: 2px;
    left: 5px;
    background: var(--color-secondary-background);
    border-radius: 180px;
    box-shadow: 0px 5px 10px rgba(0, 0, 0, 0.2);
    transition: ease-in-out 0.3s all;
  }
  .info-tab {
    margin-left: 10px;
  }
  .info-tab button {
    padding: 5px 10px 7px 12px;
    background: var(--color-secondary);
    border-radius: 50px;
    margin-bottom: 0;
    margin-top: 0;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1;
    border: none;
  }
  .tab-list #create-tab {
    padding: 1px 10px;
    margin: 0;
    outline: 0;
    border: 1px solid transparent;
    border-radius: var(--border-radius);
    background-color: var(--color-background);
    font-size: var(--font-size-large);
    margin-left: 0.5rem;
    position: relative;
    color: var(--color-secondary);
    border-color: var(--color-secondary);
    transition: ease-in-out 0.3s all;
    font-weight: 100;
    line-height: 27px;
  }
  .tab-list #create-tab:hover {
    background-color: var(--color-secondary);
    border-color: transparent;
    color: var(--color-primary);
  }
  .tab-list__item {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    flex-wrap: wrap;
    height: auto;
    margin-left: 10px;
  }
  .tab-list__item:first-child {
    margin-left: 0;
  }
  .tab-list__item--content {
    overflow-x: hidden;
    overflow-y: scroll;
    font-weight: 100;
    font-family: var(--font-family-mono);
  }
  .tab-list__item--content::-webkit-scrollbar {
    width: var(--sb-size);
    cursor: pointer;
  }
  .tab-list__item--content::-webkit-scrollbar-track {
    background: var(--sb-track-color);
    border-radius: 8px;
    cursor: pointer;
  }
  .tab-list__item--content::-webkit-scrollbar-thumb {
    background: var(--sb-thumb-color);
    border-radius: 8px;
    border: 3px solid #282d2f;
    cursor: pointer;
  }
  @supports not selector(::-webkit-scrollbar) {
    .tab-list__item--content {
      scrollbar-color: var(--sb-thumb-color) var(--sb-track-color);
    }
  }
  .tab-list__item .tab-list__item--content {
    display: none;
    background-color: var(--color-secondary);
    min-height: 92vh;
    padding: var(--padding-base);
    border: none;
    outline: 0;
    position: absolute;
    top: 45px;
    left: 10px;
    height: 91%;
    width: calc(100% - calc(var(--padding-base) * 4));
    @media screen and (max-width: 800px) {
      width: calc(100% - calc(var(--padding-base) * 2));
      
    }
  }
  .tab-list__item:last-child {
    margin-right: 10px;
    border-right: 1px solid var(--color-secondary) !important;
  }
  .tab-list__item label:hover button {
    display: block;
  }
  .tab-list__item label {
    background-color: var(--color-background);
    width: 150px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 5px 7px 10px;
    border-top-left-radius: var(--border-radius);
    border-top-right-radius: var(--border-radius);
    cursor: pointer;
  }
  .tab-list__item label span {
    color: var(--color-primary);
    text-overflow: ellipsis;
    white-space: nowrap;
    width: 80%;
    overflow: hidden;
  }
  .tab-list__item label button {
    background-color: var(--color-button-background);
    border-radius: 50%;
    box-shadow: var(--box-shadow-none);
    outline: 0;
    border: 0;
    transition: ease 0.3s all;
    display: none;
    cursor: pointer;
    padding: 8px 1px;
    margin: 0;
    height: 0;
    line-height: 1px;
    transform: rotate(-45deg);
    color: var(--color-primary);
  }
  .tab-list__item label button.delete-tab {
    background-color: transparent;
    padding: 8px 5px;
    margin: 0 5px;
    transform: rotate(0deg);
  }
  .tab-list__item label button.delete-tab:hover {
    background-color: var(--color-button-delete) !important;
  }
  .tab-list__item input[type="radio"] {
    display: none;
  }
  .tab-list__item input:checked ~ .tab-list__item--content {
    display: block;
  }
  .tab-list__item input:checked ~ label {
    background-color: var(--color-secondary);
    transition: background-color ease 0.3s;
  }
  .tab-list__item input:checked ~ label button:hover {
    background-color: var(--color-button-hover);
  }
  *[contenteditable="true"]:focus,
  *[contenteditable="true"]:active {
    border: none;
    outline: none;
  }

  .tab-list::-webkit-scrollbar {
    width: var(--scrollbar-width);
    height: var(--scrollbar-height);
  }
  .tab-list::-webkit-scrollbar-track {
    background: var(--color-secondary-background);
  }
  .tab-list::-webkit-scrollbar-thumb {
    background: var(--color-scrollbar-thumb);
    border-radius: var(--border-radius);
  }
  .tab-list::-webkit-scrollbar-thumb:hover {
    background: var(--color-scrollbar-hover);
  }
  #modals {
    @starting-style {
      display: block;
      opacity: 1;
      scale: 0;
      transition: ease-in-out 1s all;
    }
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      padding: 0;
    }
    dialog {
      padding: 0rem 1rem 0 1rem;
      display: none;
      opacity: 0;
      scale: 1;
      max-height: fit-content;
      border-radius: 15px;
      box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5);
      overflow: hidden;
      background-color: var(--color-background);
      color: var(--color-primary) !important;
      border: 0px;
      .info-content__header {
        text-align: center;
        p {
          text-align: justify;
        }
      }
      .info-content__main {
        padding: 0rem 1rem;
        ol {
          padding-left: 2rem;
          li ul {
            padding-left: 2rem;
          }
        }
      }
      .info-content__footer {
        padding: 0 1rem 1rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        button {
          padding: 10px 30px;
          border: 1px solid var(--color-background);
          background-color: var(--color-button-background);
          color: var(--color-primary);
          box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5);
        }
      }
      .info-content__footer--column {
        a {
          color: var(--color-primary);
        }
      }
    }
    dialog[open] {
      display: block;
      opacity: 1;
      scale: 1;
      width: auto;
      max-width: 600px;
      height: auto;
    }
    #info-license form[method="dialog"],
    #info-terms form[method="dialog"] {
      width: 100%;
      height: auto;
      text-align: right;
      button {
        margin-top: 1rem;
        background-color: transparent;
        border: none;
        color: var(--color-primary);
      }
    }
  }

  #context-menu {
    display: none;
    position: fixed;
    background-color: var(--color-background);
    border: 1px solid var(--color-secondary);
    border-radius: var(--border-radius);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    z-index: 1000;
    min-width: 200px;
    padding: 5px 0;
  }

  .context-menu__item {
    padding: 8px 12px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-primary);
    transition: background-color 0.2s;
    font-size: 0.95rem;
  }

  .context-menu__item:hover {
    background-color: var(--color-secondary);
  }

  .context-menu__item .shortcut {
    color: var(--color-primary);
    opacity: 0.6;
    font-size: 0.8rem;
    font-weight: 400;
    margin-left: 12px;
    padding: 2px 4px;
    background-color: var(--color-secondary);
    border-radius: 3px;
  }

  .context-menu__item:hover .shortcut {
    opacity: 0.8;
  }

  .context-menu__item[data-action="bold"] {
    font-weight: bold;
  }

  .context-menu__item[data-action="italic"] {
    font-style: italic;
  }

  .context-menu__item[data-action="underline"] {
    text-decoration: underline;
  }

  .context-menu__separator {
    height: 1px;
    background-color: var(--color-secondary);
    margin: 5px 0;
  }

  .context-menu__item[data-action="undo"],
  .context-menu__item[data-action="redo"] {
    opacity: 0.7;
  }

  .context-menu__item[data-action="undo"]:hover,
  .context-menu__item[data-action="redo"]:hover {
    opacity: 1;
  }

  .context-menu__item[data-requires-selection="true"].disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .context-menu__item[data-requires-selection="true"].disabled:hover {
    background-color: transparent;
  }

  .context-menu__item[data-requires-selection="true"].disabled .shortcut {
    opacity: 0.3;
  }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  const darkModeToggle = document.getElementById('dark-mode-toggle');
  
  // Verificar preferencia guardada o del sistema
  const savedMode = localStorage.getItem('darkMode');
  const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  
  if (savedMode !== null) {
    document.documentElement.classList.toggle('light-mode', savedMode === 'false');
    darkModeToggle.checked = savedMode === 'false';
  } else if (!systemPrefersDark) {
    document.documentElement.classList.add('light-mode');
    darkModeToggle.checked = true;
  }
  
  // Manejar el cambio
  darkModeToggle.addEventListener('change', (e) => {
    const isLightMode = e.target.checked;
    document.documentElement.classList.toggle('light-mode', isLightMode);
    localStorage.setItem('darkMode', !isLightMode);
  });

  let tabIdCounter = 1; // Contador global para generar IDs únicos

  // Inicializa el contenido y eventos
  function init() {
    restoreContent();
    initializeTabIdCounter(); // Ajusta el contador de IDs
    setupEventListeners();
  }

  // Restaura el contenido guardado en localStorage al cargar la página
  function restoreContent() {
    const tabsData = JSON.parse(localStorage.getItem('tabsData')) || [];
    const tabList = document.querySelector('.tab-list');

    // Clear existing tabs
    tabList.querySelectorAll('.tab-list__item').forEach(item => item.remove());

    tabsData.forEach(({ id, content, name }) => {
      const newTab = document.createElement('div');
      newTab.className = 'tab-list__item';
      newTab.innerHTML = `
        <input type="radio" name="body-tab" id="${id}">
        <label for="${id}">
          <span>${name || 'Nuevo'}</span>
          <button class="edit-name-tab">✏</button>
          <button class="delete-tab">x</button>
        </label>
        <div class="tab-list__item--content" contenteditable="true">${content}</div>
      `;
      tabList.insertBefore(newTab, document.getElementById('create-tab'));
    });

    setupTabEditing();
    setupTabContentEditing();
    setupTabDeletion();
  }

  // Ajusta el contador de IDs basado en los existentes
  function initializeTabIdCounter() {
    const tabs = document.querySelectorAll('.tab-list__item');
    if (tabs.length > 0) {
      tabs.forEach(tab => {
        const id = tab.querySelector('input').id;
        const number = parseInt(id.split('-').pop());
        if (number >= tabIdCounter) {
          tabIdCounter = number + 1;
        }
      });
    }
  }

  // Configura los eventos necesarios
  function setupEventListeners() {
    window.addEventListener('beforeunload', saveContent);
    setupTabEditing();
    setupTabContentEditing();
    setupCreateTabButton();
  }

  // Guarda el contenido en localStorage cuando se cierra la página
  function saveContent() {
    const tabList = document.querySelector('.tab-list');
    const tabs = tabList.querySelectorAll('.tab-list__item');
    const tabsData = [];

    tabs.forEach((item, index) => {
      const content = item.querySelector('.tab-list__item--content').innerHTML;
      const id = item.querySelector('input').id;
      const name = item.querySelector('label span').innerText;
      tabsData.push({ id, content, name });
    });

    localStorage.setItem('tabsData', JSON.stringify(tabsData));
  }

  // Reemplaza la función predeterminada del tabulador y aplica atajos de teclado
  function setupTabContentEditing() {
    document.querySelectorAll('.tab-list__item--content').forEach(editor => {
      // Solo manejar el tabulador
      editor.addEventListener('keydown', function(event) {
        if (event.key === 'Tab') {
          event.preventDefault();
          document.execCommand('insertText', false, '    ');
        }
      });
    });
  }

  // Configura los botones de edición de nombre de las pestañas
  function setupTabEditing() {
    document.querySelectorAll('.edit-name-tab').forEach(button => {
      button.addEventListener('click', function(event) {
        event.stopPropagation();
        const tabItem = this.closest('.tab-list__item');
        const label = tabItem.querySelector('label');
        const span = label.querySelector('span');
        label.setAttribute('contenteditable', 'true');
        span.focus();
        
        // Seleccionar solo el texto dentro del span
        const range = document.createRange();
        range.selectNodeContents(span);
        const selection = window.getSelection();
        selection.removeAllRanges();
        selection.addRange(range);

        function handleClickOutside(event) {
          if (!label.contains(event.target) && label.isContentEditable) {
            label.removeAttribute('contenteditable');
            saveContent(); // Guarda el contenido cuando se hace clic fuera
          }
        }
        
        document.addEventListener('click', handleClickOutside);
        
        label.addEventListener('keydown', function(event) {
          if (event.key === 'Enter') {
            event.preventDefault();
            label.removeAttribute('contenteditable');
            saveContent(); // Guarda el contenido cuando se presiona Enter
            updateTabIds();
          }
        });
      });
    });
  }

  // Configura el botón de crear nueva pestaña
  function setupCreateTabButton() {
    document.getElementById('create-tab').addEventListener('click', function() {
      const tabList = document.querySelector('.tab-list');
      
      // Usa el contador global para el nuevo ID
      const newTabId = `body-tab-${tabIdCounter++}`;
      
      // Crea una nueva pestaña
      const newTab = document.createElement('div');
      newTab.className = 'tab-list__item';
      newTab.innerHTML = `
        <input type="radio" name="body-tab" id="${newTabId}">
        <label for="${newTabId}">
          <span>Nuevo</span>
          <button class="edit-name-tab">✏</button>
          <button class="delete-tab">x</button>
        </label>
        <div class="tab-list__item--content" contenteditable="true"></div>
      `;
      tabList.insertBefore(newTab, this);
      
      // Configura eventos para la nueva pestaña
      setupTabEditing();
      setupTabContentEditing();
      setupTabDeletion(); // Configura eliminación para la nueva pestaña
      
      // Inicializa el contenido de la nueva pestaña en localStorage
      saveContent();
    });
  }

  // Actualiza los IDs de las pestañas existentes
  function updateTabIds() {
    document.querySelectorAll('.tab-list__item').forEach((item, index) => {
      const input = item.querySelector('input');
      const label = item.querySelector('label');
      const newId = `body-tab-${index + 1}`;
      input.id = newId;
      label.setAttribute('for', newId);
    });
  }

  // Configura los botones de eliminación de pestañas
  function setupTabDeletion() {
    document.querySelectorAll('.delete-tab').forEach(button => {
      button.addEventListener('click', function(event) {
        event.stopPropagation();
        const tabItem = this.closest('.tab-list__item');
        tabItem.remove();
        saveContent(); // Guarda el estado actualizado de las pestañas
      });
    });
  }

  // Configuración del menú contextual
  function initContextMenu() {
    const contextMenu = document.getElementById('context-menu');
    const contentEditableAreas = document.querySelectorAll('.tab-list__item--content');
    let activeEditableElement = null;
    let activeSelection = null;

    // Prevenir el menú contextual por defecto
    document.addEventListener('contextmenu', (e) => {
      e.preventDefault();
    });

    // Mostrar menú contextual
    document.addEventListener('contextmenu', (e) => {
      const target = e.target;
      const isContentEditable = target.closest('.tab-list__item--content');
      
      if (isContentEditable) {
        // Guardar el elemento editable activo
        activeEditableElement = target.closest('.tab-list__item--content');
        
        // Verificar si hay selección
        const selection = window.getSelection();
        const hasSelection = selection.toString().length > 0;
        
        if (hasSelection) {
          activeSelection = selection.getRangeAt(0).cloneRange();
        }
        
        // Actualizar estado de los elementos del menú
        contextMenu.querySelectorAll('.context-menu__item').forEach(item => {
          if (item.dataset.requiresSelection === 'true') {
            item.classList.toggle('disabled', !hasSelection);
          }
        });
        
        contextMenu.style.display = 'block';
        contextMenu.style.left = `${e.pageX}px`;
        contextMenu.style.top = `${e.pageY}px`;
      }
    });

    // Ocultar menú contextual al hacer clic
    document.addEventListener('click', () => {
      contextMenu.style.display = 'none';
    });

    // Manejar acciones del menú contextual
    contextMenu.addEventListener('click', (e) => {
      const menuItem = e.target.closest('.context-menu__item');
      if (menuItem && activeEditableElement && !menuItem.classList.contains('disabled')) {
        const action = menuItem.dataset.action;
        
        // Asegurarse de que el elemento tenga el foco
        activeEditableElement.focus();
        
        // Restaurar la selección si existe
        if (activeSelection) {
          const selection = window.getSelection();
          selection.removeAllRanges();
          selection.addRange(activeSelection);
        }
        
        // Aplicar el formato o acción
        switch (action) {
          case 'copy':
          case 'cut':
            document.execCommand(action, false, null);
            break;
          case 'paste':
            navigator.clipboard.readText().then(text => {
              document.execCommand('insertText', false, text);
            });
            break;
          case 'undo':
          case 'redo':
            document.execCommand(action, false, null);
            break;
          default:
            document.execCommand(action, false, null);
        }
        
        // Limpiar las variables
        activeEditableElement = null;
        activeSelection = null;
        
        contextMenu.style.display = 'none';
      }
    });
  }

  // Inicializar el menú contextual cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContextMenu);
  } else {
    initContextMenu();
  }

  // Inicializa el script al cargar la página
  window.onload = init;
});
</script>
