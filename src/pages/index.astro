        <div class="tab-list__item--content" contenteditable="true">${content}</div>
      `;
      tabList.insertBefore(newTab, document.getElementById('create-tab'));
    });

    setupTabEditing();
    setupTabContentEditing();
    setupTabDeletion();
  }

  // Ajusta el contador de IDs basado en los existentes
  function initializeTabIdCounter() {
    const tabs = document.querySelectorAll('.tab-list__item');
    if (tabs.length > 0) {
      tabs.forEach(tab => {
        const id = tab.querySelector('input').id;
        const number = parseInt(id.split('-').pop());
        if (number >= tabIdCounter) {
          tabIdCounter = number + 1;
        }
      });
    }
  }

  // Configura los eventos necesarios
  function setupEventListeners() {
    window.addEventListener('beforeunload', saveContent);
    setupTabEditing();
    setupTabContentEditing();
    setupCreateTabButton();
  }

  // Guarda el contenido en localStorage cuando se cierra la página
  function saveContent() {
    const tabList = document.querySelector('.tab-list');
    const tabs = tabList.querySelectorAll('.tab-list__item');
    const tabsData = [];

    tabs.forEach((item, index) => {
      const content = item.querySelector('.tab-list__item--content').innerHTML;
      const id = item.querySelector('input').id;
      const name = item.querySelector('label span').innerText;
      const isPinned = item.classList.contains('pinned');
      const emoji = item.querySelector('label span').dataset.emoji || null;
      tabsData.push({ id, content, name, isPinned, emoji });
    });

    localStorage.setItem('tabsData', JSON.stringify(tabsData));
  }

  // Reemplaza la función predeterminada del tabulador y aplica atajos de teclado
  function setupTabContentEditing() {
    document.querySelectorAll('.tab-list__item--content').forEach(editor => {
      // Solo manejar el tabulador
      editor.addEventListener('keydown', function(event) {
        if (event.key === 'Tab') {
          event.preventDefault();
          document.execCommand('insertText', false, '    ');
        }
      });
    });
  }

  // Configura los botones de edición de nombre de las pestañas
  function setupTabEditing() {
    document.querySelectorAll('.edit-name-tab').forEach(button => {
      button.addEventListener('click', function(event) {
        event.stopPropagation();
        const tabItem = this.closest('.tab-list__item');
        const label = tabItem.querySelector('label');
        const span = label.querySelector('span');
        label.setAttribute('contenteditable', 'true');
        span.focus();
        
        // Seleccionar solo el texto dentro del span
        const range = document.createRange();
        range.selectNodeContents(span);
        const selection = window.getSelection();
        selection.removeAllRanges();
        selection.addRange(range);

        function handleClickOutside(event) {
          if (!label.contains(event.target) && label.isContentEditable) {
            label.removeAttribute('contenteditable');
            saveContent(); // Guarda el contenido cuando se hace clic fuera
          }
        }
        
        document.addEventListener('click', handleClickOutside);
        
        label.addEventListener('keydown', function(event) {
          if (event.key === 'Enter') {
            event.preventDefault();
            label.removeAttribute('contenteditable');
            saveContent(); // Guarda el contenido cuando se presiona Enter
            updateTabIds();
          }
        });
      });
    });
  }

  // Configura el botón de crear nueva pestaña
  function setupCreateTabButton() {
    document.getElementById('create-tab').addEventListener('click', function() {
      const tabList = document.querySelector('.tab-list');
      
      // Usa el contador global para el nuevo ID
      const newTabId = `body-tab-${tabIdCounter++}`;
      
      // Crea una nueva pestaña
      const newTab = document.createElement('div');
      newTab.className = 'tab-list__item';
      newTab.innerHTML = `
        <input type="radio" name="body-tab" id="${newTabId}">
        <label for="${newTabId}">
          <span>Nuevo</span>
          <button class="edit-name-tab">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
              <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-8.4 8.4a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32l8.4-8.4Z" />
              <path d="M5.25 5.25a3 3 0 0 0-3 3v10.5a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3V13.5a.75.75 0 0 0-1.5 0v5.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5V8.25a1.5 1.5 0 0 1 1.5-1.5h5.25a.75.75 0 0 0 0-1.5H5.25Z" />
            </svg>
          </button>
          <button class="delete-tab">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
              <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
        </label>
        <div class="tab-list__item--content" contenteditable="true"></div>
      `;
      tabList.insertBefore(newTab, this);
      
      // Configura eventos para la nueva pestaña
      setupTabEditing();
      setupTabContentEditing();
      setupTabDeletion(); // Configura eliminación para la nueva pestaña
      
      // Seleccionar automáticamente la nueva pestaña
      const newTabInput = newTab.querySelector('input[type="radio"]');
      newTabInput.checked = true;
      
      // Enfocar el contenido editable de la nueva pestaña
      const newTabContent = newTab.querySelector('.tab-list__item--content');
      setTimeout(() => {
        newTabContent.focus();
      }, 50);
      
      // Inicializa el contenido de la nueva pestaña en localStorage
      saveContent();
    });
  }

  // Actualiza los IDs de las pestañas existentes
  function updateTabIds() {
    document.querySelectorAll('.tab-list__item').forEach((item, index) => {
      const input = item.querySelector('input');
      const label = item.querySelector('label');
      const newId = `body-tab-${index + 1}`;
      input.id = newId;
      label.setAttribute('for', newId);
    });
  }

  // Configura los botones de eliminación de pestañas
  function setupTabDeletion() {
    document.querySelectorAll('.delete-tab').forEach(button => {
      button.addEventListener('click', function(event) {
        event.stopPropagation();
        const tabItem = this.closest('.tab-list__item');
        tabItem.remove();
        saveContent(); // Guarda el estado actualizado de las pestañas
      });
    });
  }

  // Configuración del menú contextual
  function initContextMenu() {
    const contextMenu = document.getElementById('context-menu');
    const contentEditableAreas = document.querySelectorAll('.tab-list__item--content');
    let activeEditableElement = null;
    let activeSelection = null;
    let activeTabElement = null;

    // Mostrar menú contextual
    document.addEventListener('contextmenu', (e) => {
      e.preventDefault();

      const target = e.target;
      const isContentEditable = target.closest('.tab-list__item--content');
      
      const isTabLabel = target.closest('.tab-list__item label');
      
      if (isContentEditable) {
        // Guardar el elemento editable activo
        activeEditableElement = target.closest('.tab-list__item--content');
        
        // Verificar si hay selección
        const selection = window.getSelection();
        const hasSelection = selection.toString().length > 0;
        
        if (hasSelection) {
          activeSelection = selection.getRangeAt(0).cloneRange();
        }
        
        // Mostrar solo opciones de texto
        contextMenu.querySelectorAll('.context-menu__item').forEach(item => {
          if (item.dataset.requiresSelection === 'true') {
            item.classList.toggle('disabled', !hasSelection);
          }
          if (item.dataset.context === 'tab') {
            item.style.display = 'none';
          } else {
            item.style.display = 'block';
          }
        });
        
        // Mostrar separadores en contexto de texto
        contextMenu.querySelectorAll('.context-menu__separator').forEach(separator => {
          separator.style.display = 'block';
        });
        
        contextMenu.style.display = 'block';
        contextMenu.style.left = `${e.pageX}px`;
        contextMenu.style.top = `${e.pageY}px`;
      } else if (isTabLabel) {
        // Contexto de pestaña
        activeTabElement = target.closest('.tab-list__item');
        activeEditableElement = null;
        activeSelection = null;
        
        // Verificar si la pestaña está fijada
        const isPinned = activeTabElement.classList.contains('pinned');
        const pinTabText = document.getElementById('pin-tab-text');
        pinTabText.textContent = isPinned ? 'Desfijar' : 'Fijar';
        
        // Mostrar solo opciones de pestaña
        contextMenu.querySelectorAll('.context-menu__item').forEach(item => {
          if (item.dataset.context === 'tab') {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
        
        // Ocultar separadores también
        contextMenu.querySelectorAll('.context-menu__separator').forEach(separator => {
          separator.style.display = 'none';
        });
        
        contextMenu.style.display = 'block';
        contextMenu.style.left = `${e.pageX}px`;
        contextMenu.style.top = `${e.pageY}px`;
      }
    });

    // Ocultar menú contextual al hacer clic
    document.addEventListener('click', () => {
      contextMenu.style.display = 'none';
    });

    // Manejar acciones del menú contextual
    contextMenu.addEventListener('click', (e) => {
      const menuItem = e.target.closest('.context-menu__item');
      if (menuItem && !menuItem.classList.contains('disabled')) {
        const action = menuItem.dataset.action;
        
        if (action === 'pin-tab' && activeTabElement) {
          handlePinTab(activeTabElement);
        } else if (activeEditableElement) {
          // Asegurarse de que el elemento tenga el foco
          activeEditableElement.focus();
          
          // Restaurar la selección si existe
          if (activeSelection) {
            const selection = window.getSelection();
            selection.removeAllRanges();
            selection.addRange(activeSelection);
          }
          
          // Aplicar el formato o acción
          switch (action) {
            case 'copy':
            case 'cut':
              document.execCommand(action, false, null);
              break;
            case 'paste':
              navigator.clipboard.readText().then(text => {
                document.execCommand('insertText', false, text);
              });
              break;
            case 'undo':
            case 'redo':
              document.execCommand(action, false, null);
              break;
            default:
              document.execCommand(action, false, null);
          }
        }
        
        // Limpiar las variables
        activeEditableElement = null;
        activeSelection = null;
        activeTabElement = null;
        
        contextMenu.style.display = 'none';
      }
    });
    
    // Manejar clic del botón medio para cerrar pestañas
    document.addEventListener('auxclick', (e) => {
      if (e.button === 1) { // Botón medio del ratón
        const isTabLabel = e.target.closest('.tab-list__item label');
        if (isTabLabel) {
          e.preventDefault();
          const tabElement = e.target.closest('.tab-list__item');
          tabElement.remove();
          saveContent();
        }
      }
    });
  }

  // Función para detectar emoticonos en texto
  function detectEmojiInText(text) {
    const emojiRegex = /[\u{1F600}-\u{1F64F}]|[\u{1F300}-\u{1F5FF}]|[\u{1F680}-\u{1F6FF}]|[\u{1F1E0}-\u{1F1FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/gu;
    const matches = text.match(emojiRegex);
    return matches ? matches[0] : null;
  }

  // Función para manejar el fijar/desfijar pestañas
  function handlePinTab(tabElement) {
    const isPinned = tabElement.classList.contains('pinned');
    
    if (isPinned) {
      unfixTab(tabElement);
    } else {
      // Verificar si hay emoticono en el texto del nombre
      const labelSpan = tabElement.querySelector('label span');
      const tabName = labelSpan.textContent.trim();
      const emojiInText = detectEmojiInText(tabName);
      
      if (emojiInText) {
        pinTab(tabElement, emojiInText);
      } else {
        // Por ahora usar un emoticono por defecto
        pinTab(tabElement, '📝');
      }
    }
  }

  // Función para fijar una pestaña
  function pinTab(tabElement, emoji) {
    tabElement.classList.add('pinned');
    const label = tabElement.querySelector('label');
    const labelSpan = tabElement.querySelector('label span');
    label.setAttribute('data-emoji', emoji);
    labelSpan.dataset.emoji = emoji;
    
    // Reorganizar pestañas: fijadas a la izquierda
    reorderTabs();
    saveContent();
  }

  // Función para desfijar una pestaña
  function unfixTab(tabElement) {
    tabElement.classList.remove('pinned');
    const label = tabElement.querySelector('label');
    const labelSpan = tabElement.querySelector('label span');
    label.removeAttribute('data-emoji');
    delete labelSpan.dataset.emoji;
    
    // Reorganizar pestañas: desfijadas a la derecha
    reorderTabs();
    saveContent();
  }

  // Función para reorganizar pestañas: fijadas a la izquierda, normales a la derecha
  function reorderTabs() {
    const tabList = document.querySelector('.tab-list');
    const createTabButton = document.getElementById('create-tab');
    const allTabs = Array.from(tabList.querySelectorAll('.tab-list__item'));
    
    // Separar pestañas fijadas y normales
    const pinnedTabs = allTabs.filter(tab => tab.classList.contains('pinned'));
    const normalTabs = allTabs.filter(tab => !tab.classList.contains('pinned'));
    
    // Remover todas las pestañas del DOM
    allTabs.forEach(tab => tab.remove());
    
    // Reinsertar en orden: primero las fijadas, luego las normales
    pinnedTabs.forEach(tab => {
      tabList.insertBefore(tab, createTabButton);
    });
    
    normalTabs.forEach(tab => {
      tabList.insertBefore(tab, createTabButton);
    });
  }

  // Inicializar el menú contextual cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContextMenu);
  } else {
    initContextMenu();
  }

  function showUpdateModal() {
    if (document.querySelector('.update-modal')) return;

    const modal = document.createElement('div');
    modal.className = 'update-modal';

    modal.innerHTML = `
      <div class="update-modal__content">
        <h3>Actualización disponible</h3>
        <p>
          Hay una nueva versión del bloc de notas.
          Guarda tus notas en un lugar seguro antes de actualizar.
        </p>
        <div class="update-modal__actions">
          <button id="update-now">Actualizar</button>
          <button id="update-later">Ahora no</button>
        </div>
      </div>
    `;

    document.body.appendChild(modal);

    document.getElementById('update-now').onclick = () => {
      window.location.reload(true);
    };

    document.getElementById('update-later').onclick = () => {
      modal.remove();
    };
  }

  // Inicializa el script al cargar la página
  window.onload = init;
});

if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker
      .register('/service-worker.js')
