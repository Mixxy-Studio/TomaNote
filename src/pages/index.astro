---
// Layouts
import Layout from "../layouts/Layout.astro";

// Components
import Createtab from "../components/Createtab.astro";
import DarklightButton from "../components/DarklightButton.astro";
import InfoButton from "../components/InfoButton.astro";
import Modalsinfo from "../components/Modalsinfo.astro";
import ContextualMenu from "../components/ContextualMenu.astro";
---

<Layout>
  
  <div dir="ltr" class="tab-list">
    
    <Createtab />
    <DarklightButton />
    <InfoButton />

  </div>
  
  <Modalsinfo />
  <ContextualMenu />

</Layout>

<script>
import { initNotepad } from '../lib/scripts/entry.js';

// Inicializar de forma segura con timeout
document.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => {
    initNotepad().catch(error => {
      console.error('Error en sistema modular:', error);
      console.log('Continuando con funcionalidad inline...');
    });
  }, 100); // Pequeño delay para asegurar que el DOM está listo
});
</script>
