---
// Layouts
import Layout from "../layouts/Layout.astro";

// Components
import Modalsinfo from "../components/Modalinfo.astro";
import ContextualMenu from "../components/ContextualMenu.astro";
import FloatingMenu from "../components/FloatingMenu.astro";

// Modals
import CloseTabConfirmation from "../components/modals/CloseTabConfirmation.astro";
---

<Layout>
  <CloseTabConfirmation />
  <div dir="ltr" class="tab-list flex flex-row justify-start items-start w-full h-full max-w-[100dvw] overflow-x-auto z-[999]">
    <span id="tab-list-anchor" class="hidden"></span>
  </div>

  <Modalsinfo />
  <ContextualMenu />
  <FloatingMenu />
</Layout>

<script>
  import { initNotepad } from "../lib/scripts/entry.js";

  // Inicializar de forma segura con timeout
  document.addEventListener("DOMContentLoaded", () => {
    setTimeout(() => {
      initNotepad().catch((error) => {
        console.error("Error en sistema modular:", error);
      });
    }, 100); // Pequeño delay para asegurar que el DOM está listo
  });
</script>
