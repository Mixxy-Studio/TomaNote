---
import Layout from "../layouts/Layout.astro";
import { getLang, useTranslations } from "../i18n/utils";

const lang = getLang();
const t = useTranslations(lang);

const title = t("seo.privacy.title");
const description = t("seo.privacy.description");
---

<Layout>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "name": "Home", "position": 1, "item": "https://tomanote.app"},
        {"@type": "ListItem", "name": "Privacy", "position": 2}
      ]
    }
  </script>
  <article id="tn-content-privacy" class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 overflow-scroll!">
    <div class="container mx-auto px-4 py-12! md:py-16! lg:py-20! max-w-4xl">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6! md:p-8! lg:p-10!">
        <h1 class="text-4xl! md:text-5xl! font-extrabold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent mb-8">{t("privacy.main-title")}</h1>

        <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300 mb-8 leading-relaxed">{t("privacy.intro")}</p>

        <div class="space-y-8!">
          <section>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              {t("privacy.storage-title")}
            </h2>
            <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">{t("privacy.storage-description")}</p>
            <ul class="space-y-3 bg-gray-50 dark:bg-gray-700/50 rounded-xl p-5 md:p-6">
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{t("privacy.storage-item1")}</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{t("privacy.storage-item2")}</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{t("privacy.storage-item3")}</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{t("privacy.storage-item4")}</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>{t("privacy.storage-item5")}</span>
              </li>
            </ul>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              {t("privacy.no-account-title")}
            </h2>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 p-4 rounded-r-lg">{t("privacy.no-account-description")}</p>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              {t("privacy.security-title")}
            </h2>
            <div class="bg-amber-50 dark:bg-amber-900/20 border-l-4 border-amber-500 p-4 rounded-r-lg">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                {t("privacy.security-description")}
                <span class="font-semibold text-amber-700 dark:text-amber-400">{t("privacy.security-recommendation")}</span>
              </p>
            </div>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              {t("privacy.changes-title")}
            </h2>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{t("privacy.changes-description")}</p>
          </section>
        </div>

        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <a href="/" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors duration-200 group">
            <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            {t("privacy.back")}
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
