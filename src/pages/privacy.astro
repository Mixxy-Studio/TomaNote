---
import Layout from "../layouts/Layout.astro";

const title = "Privacy Policy - TomaNote";
const description = "TomaNote privacy policy - Your notes are stored locally in your browser. No data is collected or transmitted.";
---

<Layout>
  <article id="tn-content-privacy" class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 overflow-scroll!">
    <div class="container mx-auto px-4 py-12! md:py-16! lg:py-20! max-w-4xl">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6! md:p-8! lg:p-10!">
        <h1 class="text-4xl! md:text-5xl! font-extrabold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent mb-8">Privacy Policy</h1>

        <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300 mb-8 leading-relaxed">At TomaNote, we value your privacy. This policy explains how your data is handled.</p>

        <div class="space-y-8!">
          <section>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              Data Storage
            </h2>
            <p class="text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">All your notes are stored locally in your browser's LocalStorage. We do not have any servers that store your data. This means:</p>
            <ul class="space-y-3 bg-gray-50 dark:bg-gray-700/50 rounded-xl p-5 md:p-6">
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>Your notes never leave your device</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>We cannot access your notes</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>We do not collect any personal information</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>No cookies are used for tracking</span>
              </li>
              <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span>No analytics or third-party tracking</span>
              </li>
            </ul>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              No Account Required
            </h2>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 p-4 rounded-r-lg">TomaNote works completely anonymously. No email, no registration, no account needed. You are in full control of your data.</p>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              Data Security
            </h2>
            <div class="bg-amber-50 dark:bg-amber-900/20 border-l-4 border-amber-500 p-4 rounded-r-lg">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                Data saved in this notepad is stored in your browser's LocalStorage, which does not guarantee encryption.
                <span class="font-semibold text-amber-700 dark:text-amber-400">We recommend not storing sensitive or private information.</span>
              </p>
            </div>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              Changes to This Policy
            </h2>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">We may update this policy from time to time. Any changes will be posted on this page.</p>
          </section>
        </div>

        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <a href="/" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors duration-200 group">
            <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Back to TomaNote
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
