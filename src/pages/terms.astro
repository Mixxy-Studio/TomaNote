---
import Layout from "../layouts/Layout.astro";

const title = "Terms of Use - TomaNote";
const description = "TomaNote terms of use - Storage limits, data security, and URL safety guidelines.";
---

<Layout>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "name": "Home", "position": 1, "item": "https://tomanote.app"},
        {"@type": "ListItem", "name": "Terms", "position": 2}
      ]
    }
  </script>
  <article id="tn-content-terms" class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800">
    <div class="container mx-auto px-4 py-12 md:py-16 lg:py-20 max-w-4xl">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 md:p-8 lg:p-10">
        <h1 class="text-4xl! md:text-5xl! font-extrabold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent mb-8">Terms of Use</h1>

        <div class="space-y-8">
          <section>
            <p class="text-lg md:text-xl text-gray-700 dark:text-gray-300 mb-6 leading-relaxed bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-600 p-4 rounded-r-lg">Please read these terms carefully before using TomaNote.</p>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              Storage Limit
            </h2>
            <div class="bg-amber-50 dark:bg-amber-900/20 border-l-4 border-amber-500 p-4 rounded-r-lg">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                This notepad uses your browser's LocalStorage to save data. Although the storage limit is
                <span class="font-bold text-amber-700 dark:text-amber-400">5 MB</span>, we recommend avoiding large volumes of text. Browser storage is limited and may be affected by saving large amounts of data.
                <span class="font-semibold text-amber-700 dark:text-amber-400">If you reach the limit, you may lose data — please back up your notes regularly.</span>
              </p>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Tip: Export your notes regularly to avoid data loss</span>
            </div>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              Data Security
            </h2>
            <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-r-lg">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                Data saved in this notepad is
                <span class="font-bold text-red-700 dark:text-red-400">not encrypted</span> and is stored in your browser's LocalStorage, which does not guarantee security.
                <span class="font-semibold text-red-700 dark:text-red-400">We recommend not storing sensitive or private information here</span>, as it may be vulnerable to unauthorized access if others have access to your device or browser.
              </p>
            </div>
            <div class="mt-4 flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg">
              <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
              <span>Security note: Never store passwords, credit card details, or other sensitive information</span>
            </div>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              URL Safety
            </h2>
            <div class="bg-yellow-50 dark:bg-yellow-900/20 border-l-4 border-yellow-500 p-4 rounded-r-lg">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                Make sure you are using a trusted and secure URL when accessing the notepad. Avoid accessing it from suspicious links or unsecured public networks, as you may be exposed to phishing attacks or data theft.
                <span class="font-semibold text-yellow-700 dark:text-yellow-400">The development team is not responsible for data loss due to improper use or insecure access.</span>
              </p>
            </div>
            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
              <div class="flex items-center gap-2 text-sm text-green-700 dark:text-green-400 bg-green-50 dark:bg-green-900/20 p-3 rounded-lg">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                <span>✓ Always check the URL is correct</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-900/20 p-3 rounded-lg">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>⚠ Avoid public Wi-Fi when possible</span>
              </div>
            </div>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
              License
            </h2>
            <div class="bg-purple-50 dark:bg-purple-900/20 border-l-4 border-purple-500 p-4 rounded-r-lg">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                TomaNote is open source software licensed under
                <a href="https://www.gnu.org/licenses/agpl-3.0.en.html" target="_blank" rel="noopener noreferrer" class="text-purple-600 dark:text-purple-400 hover:text-purple-700 dark:hover:text-purple-300 font-semibold underline decoration-2 underline-offset-2 transition-colors"> GNU Affero General Public License (AGPL) v3.0 </a>.
              </p>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-700/50 p-3 rounded-lg">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
              <span>Open source • Free to use • Community driven</span>
            </div>
          </section>

          <section class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 p-5 rounded-xl text-center">
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">By using TomaNote, you acknowledge that you have read, understood, and agree to be bound by these terms.</p>
            </div>
          </section>
        </div>

        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <a href="/" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold transition-colors duration-200 group">
            <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Back to TomaNote
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
